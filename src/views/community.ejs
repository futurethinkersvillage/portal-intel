
<div x-data="{ activeCategory: '' }">
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-8">
    <div>
      <h1 class="text-2xl font-display font-bold">Community Directory</h1>
      <p class="text-sm text-stone-400 mt-1">Builders, makers, and operators networking across BC &amp; Alberta</p>
    </div>
    <% if (user) { %>
      <a href="/profile/edit" class="text-sm text-brand-400 hover:text-brand-300 transition">+ Add Your Profile</a>
    <% } else { %>
      <a href="/" class="text-sm text-stone-500 hover:text-stone-300 transition">Sign in to list your project</a>
    <% } %>
  </div>

  <% if (profiles.length === 0) { %>
    <div class="text-center py-16">
      <div class="text-4xl mb-4">🤝</div>
      <p class="text-stone-400 mb-2">No community profiles yet.</p>
      <% if (user) { %>
        <a href="/profile/edit" class="text-sm text-brand-400 hover:text-brand-300">Be the first to add yours &rarr;</a>
      <% } %>
    </div>
  <% } else { %>

    <%
      // Group by category
      var grouped = {};
      profiles.forEach(function(p) {
        if (!grouped[p.category]) grouped[p.category] = [];
        grouped[p.category].push(p);
      });
    %>

    <% categoryOrder.forEach(function(slug) { %>
      <% if (!grouped[slug]) return; %>
      <div class="mb-10">
        <h2 class="text-sm font-semibold tracking-widest uppercase text-stone-500 mb-4 flex items-center gap-2">
          <span><%= categoryData[slug]?.icon || '' %></span>
          <span><%= categoryData[slug]?.label || slug %></span>
          <span class="text-stone-700 font-normal">(<%= grouped[slug].length %>)</span>
        </h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <% grouped[slug].forEach(function(p) { %>
            <div class="bg-stone-900 border border-stone-800 rounded-lg p-5 hover:border-stone-700 transition flex flex-col">
              <div class="flex items-center gap-3 mb-3">
                <% if (p.user_image) { %>
                  <img src="<%= p.user_image %>" alt="" class="w-9 h-9 rounded-full object-cover flex-shrink-0">
                <% } else { %>
                  <div class="w-9 h-9 rounded-full bg-brand-800 flex items-center justify-center text-brand-400 font-semibold text-sm flex-shrink-0">
                    <%= p.display_name.charAt(0).toUpperCase() %>
                  </div>
                <% } %>
                <div class="min-w-0">
                  <div class="font-medium text-sm truncate"><%= p.display_name %></div>
                  <div class="text-xs text-stone-500"><%= p.region.toUpperCase() %></div>
                </div>
              </div>
              <% if (p.tagline) { %>
                <p class="text-sm text-stone-300 mb-2 leading-relaxed font-medium"><%= p.tagline %></p>
              <% } %>
              <% if (p.description) { %>
                <p class="text-xs text-stone-500 leading-relaxed line-clamp-3 mb-2"><%= p.description %></p>
              <% } %>
              <% if (p.looking_for) { %>
                <div class="text-xs text-brand-300 bg-brand-900/30 border border-brand-800/40 rounded-lg px-2.5 py-1.5 mb-1.5">
                  <span class="text-brand-500 font-medium">Seeking:</span> <%= p.looking_for %>
                </div>
              <% } %>
              <% if (p.offering) { %>
                <div class="text-xs text-emerald-300 bg-emerald-900/20 border border-emerald-800/30 rounded-lg px-2.5 py-1.5 mb-2">
                  <span class="text-emerald-500 font-medium">Offering:</span> <%= p.offering %>
                </div>
              <% } %>
              <div class="flex-1"></div>
              <% if (p.website_url || p.contact_method) { %>
                <div class="flex items-center gap-3 mt-3 pt-3 border-t border-stone-800">
                  <% if (p.website_url) { %>
                    <a href="<%= p.website_url %>" target="_blank" rel="noopener noreferrer"
                      class="text-xs text-accent-400 hover:text-accent-300 font-medium transition">Website &rarr;</a>
                  <% } %>
                  <% if (p.contact_method) { %>
                    <span class="text-xs text-stone-500 truncate"><%= p.contact_method %></span>
                  <% } %>
                </div>
              <% } %>
            </div>
          <% }) %>
        </div>
      </div>
    <% }) %>

  <% } %>
</div>
