
<% if (user) { %>
  <script>window.location.href = '<%= user.onboarded ? "/feed" : "/preferences" %>';</script>
<% } %>

<div class="max-w-3xl mx-auto text-center py-16">
  <div class="mb-8">
    <span class="inline-block text-xs font-medium tracking-widest uppercase text-brand-400 bg-brand-500/10 px-3 py-1 rounded-full mb-4">BC &amp; Alberta</span>
    <h1 class="text-4xl sm:text-5xl font-display tracking-tight mb-4">Regional Intelligence<br>for People Who Act</h1>
    <p class="text-lg text-stone-400 max-w-xl mx-auto leading-relaxed">
      Curated opportunities in land, grants, infrastructure, operators, events, and jobs across British Columbia and Alberta. Not noise. Not commentary. Actionable signal.
    </p>
  </div>

  <div class="grid sm:grid-cols-3 gap-4 mb-12 text-left">
    <div class="bg-stone-900 border border-stone-800 rounded-lg p-5">
      <div class="text-brand-400 font-semibold mb-1">Weekly Intel Brief</div>
      <p class="text-sm text-stone-400 leading-relaxed">The top opportunities across all categories, editorially curated and delivered to your inbox.</p>
    </div>
    <div class="bg-stone-900 border border-stone-800 rounded-lg p-5">
      <div class="text-accent-400 font-semibold mb-1">Full Intel Feed</div>
      <p class="text-sm text-stone-400 leading-relaxed">Everything we find — filterable by category, region, and type. Your private intelligence dashboard.</p>
    </div>
    <div class="bg-stone-900 border border-stone-800 rounded-lg p-5">
      <div class="text-brand-400 font-semibold mb-1">Daily Alerts</div>
      <p class="text-sm text-stone-400 leading-relaxed">Instant notifications for the categories you care most about. Never miss a time-sensitive opportunity.</p>
    </div>
  </div>

  <div class="mb-12">
    <h2 class="text-sm font-medium tracking-widest uppercase text-stone-500 mb-4">What We Cover</h2>
    <div class="flex flex-wrap justify-center gap-2">
      <span class="bg-emerald-500/10 text-emerald-400 text-sm px-3 py-1.5 rounded-full">🏔️ Land &amp; Property</span>
      <span class="bg-amber-500/10 text-amber-400 text-sm px-3 py-1.5 rounded-full">💰 Grants &amp; Funding</span>
      <span class="bg-sky-500/10 text-sky-400 text-sm px-3 py-1.5 rounded-full">🔧 Operators &amp; Trades</span>
      <span class="bg-violet-500/10 text-violet-400 text-sm px-3 py-1.5 rounded-full">💼 Jobs &amp; Work</span>
      <span class="bg-rose-500/10 text-rose-400 text-sm px-3 py-1.5 rounded-full">📅 Events &amp; Education</span>
      <span class="bg-orange-500/10 text-orange-400 text-sm px-3 py-1.5 rounded-full">🏗️ Infrastructure &amp; Building</span>
    </div>
  </div>

  <div class="bg-stone-900 border border-stone-800 rounded-xl p-8 max-w-md mx-auto">
    <h2 class="text-xl font-semibold mb-2">Get Started</h2>
    <p class="text-sm text-stone-400 mb-6">Sign in to access the Intel Feed and start receiving weekly briefs.</p>
    <a href="/api/auth/sign-in/social?provider=google&callbackURL=/preferences"
       class="inline-flex items-center gap-3 bg-white text-stone-900 font-medium px-6 py-3 rounded-lg hover:bg-stone-100 transition w-full justify-center">
      <svg class="w-5 h-5" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
      Continue with Google
    </a>
  </div>

  <div class="mt-16 text-sm text-stone-500">
    <p>A <a href="https://portal.place" class="text-brand-400 hover:text-brand-300">Portal.Place</a> product</p>
  </div>
</div>
