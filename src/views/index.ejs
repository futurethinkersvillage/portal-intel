
<% if (user && user.role === 'admin') { %>
  <script>window.location.href = '/feed';</script>
<% } else if (user) { %>
  <script>window.location.href = '/waitlist/thanks';</script>
<% } %>

<div class="max-w-2xl mx-auto">
  <div class="text-center pt-12 sm:pt-20 pb-8">
    <div class="inline-flex items-center gap-2 text-xs font-medium tracking-widest uppercase text-brand-400 bg-brand-500/10 border border-brand-500/20 px-4 py-1.5 rounded-full mb-8">
      <span class="w-1.5 h-1.5 rounded-full bg-brand-400 animate-pulse"></span>
      Coming Soon &middot; BC &amp; Alberta
    </div>
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-display tracking-tight mb-6 leading-[1.05]">
      Regional Intelligence<br class="hidden sm:block">for People Who Act
    </h1>
    <p class="text-base sm:text-lg text-stone-400 max-w-xl mx-auto leading-relaxed mb-10">
      Curated intelligence for people actively building resilient communities. Rural land, grants, jobs, marketplace, events, and policy risks &mdash; delivered weekly.
    </p>

    <% if (typeof success !== 'undefined' && success) { %>
      <div class="bg-emerald-500/10 border border-emerald-500/20 text-emerald-300 text-sm px-5 py-4 rounded-2xl mb-6 max-w-md mx-auto flex items-center gap-3">
        <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        You're on the list. We'll be in touch when Portal Intel launches.
      </div>
    <% } %>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="bg-red-500/10 border border-red-500/20 text-red-400 text-sm px-5 py-4 rounded-2xl mb-6 max-w-md mx-auto"><%= error %></div>
    <% } %>

    <!-- Waitlist signup form -->
    <div class="bg-stone-900/60 border border-stone-800/60 rounded-2xl p-6 sm:p-8 max-w-md mx-auto mb-6">
      <form method="POST" action="/waitlist" class="space-y-4">
        <!-- Honeypot (hidden from real users) -->
        <input type="text" name="website" class="absolute opacity-0 pointer-events-none -z-10" tabindex="-1" autocomplete="off" aria-hidden="true">

        <div>
          <label for="name" class="sr-only">Name</label>
          <input type="text" id="name" name="name" placeholder="Your name"
            class="w-full bg-stone-800/60 border border-stone-700/60 rounded-xl px-4 py-3 text-sm text-stone-200 placeholder-stone-600 focus:border-brand-500/50 focus:ring-1 focus:ring-brand-500/30 focus:outline-none transition-colors">
        </div>
        <div>
          <label for="email" class="sr-only">Email</label>
          <input type="email" id="email" name="email" required placeholder="you@example.com"
            class="w-full bg-stone-800/60 border border-stone-700/60 rounded-xl px-4 py-3 text-sm text-stone-200 placeholder-stone-600 focus:border-brand-500/50 focus:ring-1 focus:ring-brand-500/30 focus:outline-none transition-colors">
        </div>
        <button type="submit" class="w-full inline-flex items-center justify-center gap-2 bg-brand-500 hover:bg-brand-600 text-white font-semibold py-3.5 rounded-xl transition-colors active:scale-[0.98] shadow-lg shadow-brand-500/20 hover:shadow-brand-500/30">
          Join the Waitlist
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </button>
      </form>

      <div class="flex items-center gap-3 my-5">
        <div class="flex-1 h-px bg-stone-800"></div>
        <span class="text-xs text-stone-600 uppercase tracking-widest">or</span>
        <div class="flex-1 h-px bg-stone-800"></div>
      </div>

      <a href="/api/auth/sign-in/social?provider=google&callbackURL=/waitlist/thanks"
        class="w-full inline-flex items-center justify-center gap-3 bg-white text-stone-900 font-semibold px-5 py-3 rounded-xl hover:bg-stone-100 transition-colors active:scale-[0.98] shadow-lg shadow-white/5 text-sm">
        <svg class="w-5 h-5" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
        Sign up with Google
      </a>

      <p class="text-xs text-stone-600 text-center mt-5">No spam. We'll only email you about Portal Intel.</p>
    </div>

    <!-- Category preview -->
    <div class="flex flex-wrap justify-center gap-2 mb-12">
      <% categories.forEach(function(cat) { %>
        <span class="<%= categoryData[cat.slug]?.badge || 'bg-stone-800 text-stone-400' %> text-xs px-3 py-1.5 rounded-full border border-<%= cat.color %>-500/20 font-medium"><%= cat.icon %> <%= cat.label %></span>
      <% }) %>
    </div>
  </div>

  <!-- Value props -->
  <div class="grid sm:grid-cols-3 gap-5 mb-16">
    <div class="bg-stone-900/40 border border-stone-800/40 rounded-2xl p-6">
      <div class="w-10 h-10 rounded-xl bg-brand-500/10 flex items-center justify-center mb-4">
        <svg class="w-5 h-5 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
      </div>
      <div class="font-semibold mb-1.5 text-sm">Weekly Intel Brief</div>
      <p class="text-xs text-stone-500 leading-relaxed">Top deals, closing grants, and upcoming meetups &mdash; curated and delivered every Sunday.</p>
    </div>
    <div class="bg-stone-900/40 border border-brand-800/30 rounded-2xl p-6">
      <div class="w-10 h-10 rounded-xl bg-brand-500/15 flex items-center justify-center mb-4">
        <svg class="w-5 h-5 text-brand-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
      </div>
      <div class="font-semibold mb-1.5 text-sm text-brand-200">Full Intel Feed</div>
      <p class="text-xs text-stone-500 leading-relaxed">Searchable, filterable, scored by relevance and urgency. Your private intelligence dashboard.</p>
    </div>
    <div class="bg-stone-900/40 border border-stone-800/40 rounded-2xl p-6">
      <div class="w-10 h-10 rounded-xl bg-amber-500/10 flex items-center justify-center mb-4">
        <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
      </div>
      <div class="font-semibold mb-1.5 text-sm">Daily Alerts</div>
      <p class="text-xs text-stone-500 leading-relaxed">Get same-day notifications for land deals, grants, and opportunities you care about.</p>
    </div>
  </div>

  <div class="text-center text-xs text-stone-600 pb-8">
    A <a href="https://portal.place" class="text-brand-400 hover:text-brand-300 transition-colors">Portal.Place</a> product &middot; BC &amp; Alberta Regional Intelligence
  </div>
</div>
