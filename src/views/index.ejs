
<% if (user) { %>
  <script>window.location.href = '<%= user.onboarded ? "/feed" : "/preferences" %>';</script>
<% } %>

<!-- Hero -->
<div class="max-w-5xl mx-auto">
  <div class="text-center pt-12 sm:pt-20 pb-8">
    <div class="inline-flex items-center gap-2 text-xs font-medium tracking-widest uppercase text-brand-400 bg-brand-500/10 border border-brand-500/20 px-4 py-1.5 rounded-full mb-8">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      British Columbia &amp; Alberta
    </div>
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-display tracking-tight mb-6 leading-[1.1]">
      Regional Intelligence<br class="hidden sm:block">for People Who Act
    </h1>
    <p class="text-base sm:text-lg text-stone-400 max-w-2xl mx-auto leading-relaxed mb-10">
      Curated intelligence for people actively building resilient communities. Rural land, grants, jobs, marketplace, events, and policy risks.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-14">
      <a href="/api/auth/sign-in/social?provider=google&callbackURL=/preferences"
         class="inline-flex items-center gap-3 bg-white text-stone-900 font-semibold px-7 py-3.5 rounded-xl hover:bg-stone-100 transition-all shadow-lg shadow-white/5 hover:shadow-white/10 active:scale-[0.98]">
        <svg class="w-5 h-5" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
        Join the Network
      </a>
      <a href="#preview" class="text-sm text-stone-500 hover:text-stone-300 transition-colors group">
        See what's inside <span class="inline-block group-hover:translate-y-0.5 transition-transform">&#8595;</span>
      </a>
    </div>

    <!-- Category pills -->
    <div class="flex flex-wrap justify-center gap-2">
      <% categories.forEach(function(cat) { %>
        <span class="<%= categoryData[cat.slug]?.badge || 'bg-stone-800 text-stone-400' %> text-xs px-3 py-1.5 rounded-full border border-<%= cat.color %>-500/20 font-medium"><%= cat.icon %> <%= cat.label %></span>
      <% }) %>
    </div>
  </div>

  <!-- Value Props -->
  <div class="grid sm:grid-cols-3 gap-5 mb-20 mt-8">
    <div class="bg-stone-900/60 border border-stone-800/60 rounded-2xl p-6 hover:border-stone-700/60 transition-colors group">
      <div class="w-10 h-10 rounded-xl bg-brand-500/10 flex items-center justify-center mb-4 group-hover:bg-brand-500/15 transition-colors">
        <svg class="w-5 h-5 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
      </div>
      <div class="font-semibold mb-1.5">Weekly Intel Brief</div>
      <p class="text-sm text-stone-400 leading-relaxed">Top deals, closing grants, and upcoming meetups -- curated and delivered every Sunday.</p>
    </div>
    <div class="bg-stone-900/60 border border-brand-800/30 rounded-2xl p-6 hover:border-brand-700/40 transition-colors group relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-brand-500/5 to-transparent pointer-events-none"></div>
      <div class="relative">
        <div class="w-10 h-10 rounded-xl bg-brand-500/15 flex items-center justify-center mb-4 group-hover:bg-brand-500/20 transition-colors">
          <svg class="w-5 h-5 text-brand-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
        </div>
        <div class="font-semibold mb-1.5 text-brand-200">Full Intel Feed</div>
        <p class="text-sm text-stone-400 leading-relaxed">Everything we find -- searchable, filterable, scored by relevance and urgency. Your private intelligence dashboard.</p>
      </div>
    </div>
    <div class="bg-stone-900/60 border border-stone-800/60 rounded-2xl p-6 hover:border-stone-700/60 transition-colors group">
      <div class="w-10 h-10 rounded-xl bg-amber-500/10 flex items-center justify-center mb-4 group-hover:bg-amber-500/15 transition-colors">
        <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
      </div>
      <div class="font-semibold mb-1.5">Daily Alerts</div>
      <p class="text-sm text-stone-400 leading-relaxed">Set alert categories and get same-day notifications for land deals, grants, and opportunities you care about.</p>
    </div>
  </div>

  <!-- Upcoming Meetups -->
  <% if (typeof upcomingMeetups !== 'undefined' && upcomingMeetups.length > 0) { %>
  <div class="mb-20">
    <div class="flex items-center justify-between mb-6">
      <h2 class="font-display font-bold text-xl flex items-center gap-2.5">
        <svg class="w-5 h-5 text-rose-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        <span class="text-rose-400">Upcoming Meetups</span>
      </h2>
      <a href="/events" class="text-xs text-stone-500 hover:text-stone-300 border border-stone-800 hover:border-stone-700 px-3 py-1.5 rounded-lg transition-colors">View all &rarr;</a>
    </div>
    <div class="grid sm:grid-cols-3 gap-4">
      <% upcomingMeetups.forEach(function(m) { %>
        <a href="/events/<%= m.slug %>" class="bg-stone-900/60 border border-stone-800/60 rounded-2xl p-5 hover:border-rose-500/30 transition-all group block">
          <div class="text-rose-400 text-xs font-semibold uppercase tracking-widest mb-2">
            <%= new Date(m.event_date).toLocaleDateString('en-CA', { month: 'short', day: 'numeric', year: 'numeric' }) %>
          </div>
          <div class="font-semibold text-sm mb-1 group-hover:text-stone-50 transition-colors"><%= m.title %></div>
          <div class="text-xs text-stone-500 flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <%= m.location %>
          </div>
          <% if (m.rsvp_count > 0) { %>
            <div class="text-xs text-stone-600 mt-2 flex items-center gap-1">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <%= m.rsvp_count %> attending
            </div>
          <% } %>
        </a>
      <% }) %>
    </div>
  </div>
  <% } %>

  <!-- Live Feed Preview -->
  <div id="preview" class="mb-16">
    <div class="text-center mb-10">
      <h2 class="font-display font-bold text-2xl sm:text-3xl mb-3">What's in the Feed Right Now</h2>
      <p class="text-stone-500 text-sm max-w-md mx-auto">Sign in to unlock the full feed, search, alerts, and weekly digest.</p>
    </div>

    <% if (typeof previewGroups !== 'undefined' && previewGroups.length > 0) { %>
      <div class="space-y-12">
        <% previewGroups.forEach(function(group) { %>
          <div>
            <div class="flex items-center gap-2.5 mb-5 pb-3 border-b border-stone-800/60">
              <span class="text-lg"><%= categoryData[group.slug]?.icon || '' %></span>
              <span class="font-display font-bold text-base <%= categoryData[group.slug]?.text || 'text-stone-500' %>"><%= categoryData[group.slug]?.label || group.slug %></span>
            </div>
            <div class="space-y-3">
              <% group.items.forEach(function(item) { %>
                <div class="bg-stone-900/50 border border-stone-800/50 rounded-xl p-5 hover:border-stone-700/60 transition-colors">
                  <div class="flex items-start gap-4">
                    <div class="flex-1 min-w-0">
                      <div class="flex flex-wrap items-center gap-2 mb-2">
                        <span class="text-xs font-medium px-2 py-0.5 rounded-full <%= categoryData[item.category]?.badge || 'bg-stone-800 text-stone-400' %>"><%= categoryData[item.category]?.label || item.category %></span>
                        <span class="text-xs text-stone-600 uppercase tracking-wide"><%= item.region %></span>
                        <% if (item.expires_at) { %>
                          <span class="text-xs text-amber-400 font-medium flex items-center gap-1">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            <%= new Date(item.expires_at).toLocaleDateString('en-CA', { month: 'short', day: 'numeric' }) %>
                          </span>
                        <% } %>
                      </div>
                      <div class="font-semibold text-sm text-stone-100 mb-2 leading-snug"><%= item.title %></div>
                      <% if (item.summary) { %>
                        <p class="text-sm text-stone-400 leading-relaxed mb-2.5 line-clamp-2"><%= item.summary %></p>
                      <% } %>
                      <% if (item.ai_actionability) { %>
                        <div class="inline-flex items-center gap-1.5 text-xs text-brand-300 bg-brand-900/40 border border-brand-800/40 px-2.5 py-1 rounded-lg font-medium">
                          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                          <%= item.ai_actionability %>
                        </div>
                      <% } %>
                    </div>
                    <div class="shrink-0">
                      <a href="/api/auth/sign-in/social?provider=google&callbackURL=/feed"
                        class="text-xs bg-brand-600 hover:bg-brand-500 text-white px-3.5 py-2 rounded-lg transition-colors font-medium whitespace-nowrap inline-flex items-center gap-1.5 active:scale-[0.97]">
                        Sign in
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                      </a>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
        <% }) %>
      </div>

      <!-- Sign up CTA -->
      <div class="mt-16 bg-gradient-to-br from-stone-900 to-stone-900/80 border border-brand-800/30 rounded-2xl p-10 sm:p-12 text-center relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-brand-500/5 via-transparent to-accent-500/5 pointer-events-none"></div>
        <div class="relative">
          <h3 class="font-display font-bold text-2xl sm:text-3xl mb-3">Ready to see everything?</h3>
          <p class="text-stone-400 text-sm mb-8 max-w-md mx-auto leading-relaxed">Full feed access, search, watchlist, daily alerts, and weekly digest. Free to join.</p>
          <a href="/api/auth/sign-in/social?provider=google&callbackURL=/preferences"
             class="inline-flex items-center gap-3 bg-white text-stone-900 font-semibold px-7 py-3.5 rounded-xl hover:bg-stone-100 transition-all shadow-lg shadow-white/5 active:scale-[0.98]">
            <svg class="w-5 h-5" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
            Join Free with Google
          </a>
        </div>
      </div>
    <% } else { %>
      <div class="bg-gradient-to-br from-stone-900 to-stone-900/80 border border-brand-800/30 rounded-2xl p-12 text-center">
        <h3 class="font-display font-bold text-2xl mb-3">Join the Network</h3>
        <p class="text-stone-400 text-sm mb-6 max-w-md mx-auto">Free access to curated land deals, grants, events, and community profiles across BC and Alberta.</p>
        <a href="/api/auth/sign-in/social?provider=google&callbackURL=/preferences"
           class="inline-flex items-center gap-3 bg-white text-stone-900 font-semibold px-7 py-3.5 rounded-xl hover:bg-stone-100 transition-all active:scale-[0.98]">
          <svg class="w-5 h-5" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
          Join Free with Google
        </a>
      </div>
    <% } %>
  </div>

  <div class="text-center text-sm text-stone-600 pb-8">
    A <a href="https://portal.place" class="text-brand-400 hover:text-brand-300 transition-colors">Portal.Place</a> product &middot; BC &amp; Alberta Regional Intelligence
  </div>
</div>
