
<% if (user) { %>
  <script>window.location.href = '<%= user.onboarded ? "/feed" : "/preferences" %>';</script>
<% } %>

<!-- Hero -->
<div class="max-w-5xl mx-auto">
  <div class="text-center py-16 mb-4">
    <span class="inline-block text-xs font-medium tracking-widest uppercase text-brand-400 bg-brand-500/10 px-3 py-1 rounded-full mb-5">BC & Alberta</span>
    <h1 class="text-4xl sm:text-6xl font-display tracking-tight mb-5 leading-tight">
      Regional Intelligence<br>for People Who Act
    </h1>
    <p class="text-lg text-stone-400 max-w-2xl mx-auto leading-relaxed mb-10">
      Curated intelligence for people actively building resilient communities. Rural land, grants, jobs, marketplace, events, and policy risks across British Columbia and Alberta.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
      <a href="/api/auth/sign-in/social?provider=google&callbackURL=/preferences"
         class="inline-flex items-center gap-3 bg-white text-stone-900 font-semibold px-7 py-3.5 rounded-xl hover:bg-stone-100 transition shadow-lg">
        <svg class="w-5 h-5" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
        Join the Network
      </a>
      <a href="#preview" class="text-sm text-stone-400 hover:text-stone-200 transition">
        See what's inside ↓
      </a>
    </div>

    <div class="flex flex-wrap justify-center gap-2 mb-6">
      <% categories.forEach(function(cat) { %>
        <span class="<%= categoryData[cat.slug]?.badge || 'bg-stone-800 text-stone-400' %> text-xs px-3 py-1.5 rounded-full border border-<%= cat.color %>-500/20"><%= cat.icon %> <%= cat.label %></span>
      <% }) %>
    </div>
  </div>

  <!-- Value props -->
  <div class="grid sm:grid-cols-3 gap-4 mb-16">
    <div class="bg-stone-900 border border-stone-800 rounded-xl p-6">
      <div class="text-2xl mb-3">📬</div>
      <div class="font-semibold mb-1">Weekly Intel Brief</div>
      <p class="text-sm text-stone-400 leading-relaxed">Top deals, closing grants, and upcoming meetups — curated and delivered every Sunday.</p>
    </div>
    <div class="bg-stone-900 border border-brand-800/40 rounded-xl p-6">
      <div class="text-2xl mb-3">🔍</div>
      <div class="font-semibold mb-1 text-brand-300">Full Intel Feed</div>
      <p class="text-sm text-stone-400 leading-relaxed">Everything we find — searchable, filterable, scored by relevance and urgency. Your private intelligence dashboard.</p>
    </div>
    <div class="bg-stone-900 border border-stone-800 rounded-xl p-6">
      <div class="text-2xl mb-3">🔔</div>
      <div class="font-semibold mb-1">Daily Alerts</div>
      <p class="text-sm text-stone-400 leading-relaxed">Set alert categories and get same-day notifications for land deals, grants, and opportunities you care about.</p>
    </div>
  </div>

  <!-- Upcoming Meetups -->
  <% if (typeof upcomingMeetups !== 'undefined' && upcomingMeetups.length > 0) { %>
  <div class="mb-16">
    <div class="flex items-center justify-between mb-5">
      <h2 class="font-display font-bold text-xl text-rose-400">📅 Upcoming Meetups</h2>
      <a href="/events" class="text-xs text-stone-500 hover:text-stone-300 border border-stone-800 px-3 py-1.5 rounded-lg transition">View all →</a>
    </div>
    <div class="grid sm:grid-cols-3 gap-4">
      <% upcomingMeetups.forEach(function(m) { %>
        <a href="/events/<%= m.slug %>" class="bg-stone-900 border border-stone-800 rounded-xl p-5 hover:border-rose-500/40 transition block">
          <div class="text-rose-400 text-xs font-semibold uppercase tracking-widest mb-2">
            <%= new Date(m.event_date).toLocaleDateString('en-CA', { month: 'short', day: 'numeric', year: 'numeric' }) %>
          </div>
          <div class="font-semibold text-sm mb-1"><%= m.title %></div>
          <div class="text-xs text-stone-500"><%= m.location %></div>
          <% if (m.rsvp_count > 0) { %>
            <div class="text-xs text-stone-600 mt-2"><%= m.rsvp_count %> attending</div>
          <% } %>
        </a>
      <% }) %>
    </div>
  </div>
  <% } %>

  <!-- Live Feed Preview -->
  <div id="preview" class="mb-16">
    <div class="text-center mb-8">
      <h2 class="font-display font-bold text-2xl mb-2">What's in the Feed Right Now</h2>
      <p class="text-stone-500 text-sm">Sign in to unlock the full feed, search, alerts, and weekly digest.</p>
    </div>

    <% if (typeof previewGroups !== 'undefined' && previewGroups.length > 0) { %>
      <div class="space-y-10">
        <% previewGroups.forEach(function(group) { %>
          <div>
            <div class="flex items-center gap-2.5 mb-4 pb-3 border-b border-stone-800">
              <span class="text-xl"><%= categoryData[group.slug]?.icon || '' %></span>
              <span class="font-display font-bold text-base <%= categoryData[group.slug]?.text || 'text-stone-500' %>"><%= categoryData[group.slug]?.label || group.slug %></span>
            </div>
            <div class="space-y-3">
              <% group.items.forEach(function(item) { %>
                <div class="bg-stone-900 border border-stone-800 rounded-xl p-5">
                  <div class="flex items-start gap-4">
                    <div class="flex-1 min-w-0">
                      <div class="flex flex-wrap items-center gap-2 mb-2">
                        <span class="text-xs font-medium px-2 py-0.5 rounded-full <%= categoryData[item.category]?.badge || 'bg-stone-800 text-stone-400' %>"><%= categoryData[item.category]?.label || item.category %></span>
                        <span class="text-xs text-stone-600 uppercase"><%= item.region %></span>
                        <% if (item.expires_at) { %>
                          <span class="text-xs text-amber-400">⏳ <%= new Date(item.expires_at).toLocaleDateString('en-CA', { month: 'short', day: 'numeric' }) %></span>
                        <% } %>
                      </div>
                      <div class="font-semibold text-sm text-stone-100 mb-2 leading-snug"><%= item.title %></div>
                      <% if (item.summary) { %>
                        <p class="text-sm text-stone-400 leading-relaxed mb-2"><%= item.summary %></p>
                      <% } %>
                      <% if (item.ai_actionability) { %>
                        <div class="inline-flex items-center gap-1 text-xs text-brand-300 bg-brand-900/40 border border-brand-800/50 px-2.5 py-1 rounded-full font-medium">
                          → <%= item.ai_actionability %>
                        </div>
                      <% } %>
                    </div>
                    <div class="shrink-0">
                      <a href="/api/auth/sign-in/social?provider=google&callbackURL=/feed"
                        class="text-xs bg-brand-500 hover:bg-brand-600 text-white px-3 py-1.5 rounded-lg transition font-medium whitespace-nowrap">
                        Sign in →
                      </a>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
        <% }) %>
      </div>

      <!-- Sign up CTA after preview -->
      <div class="mt-12 bg-stone-900 border border-brand-800/40 rounded-2xl p-10 text-center">
        <h3 class="font-display font-bold text-2xl mb-3">Ready to see everything?</h3>
        <p class="text-stone-400 text-sm mb-6 max-w-md mx-auto">Full feed access, search, watchlist, daily alerts, and weekly digest. Free to join.</p>
        <a href="/api/auth/sign-in/social?provider=google&callbackURL=/preferences"
           class="inline-flex items-center gap-3 bg-white text-stone-900 font-semibold px-7 py-3.5 rounded-xl hover:bg-stone-100 transition">
          <svg class="w-5 h-5" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
          Join Free with Google
        </a>
      </div>
    <% } else { %>
      <!-- No items yet — clean CTA -->
      <div class="bg-stone-900 border border-brand-800/40 rounded-2xl p-12 text-center">
        <h3 class="font-display font-bold text-2xl mb-3">Join the Network</h3>
        <p class="text-stone-400 text-sm mb-6 max-w-md mx-auto">Free access to curated land deals, grants, events, and community profiles across BC and Alberta.</p>
        <a href="/api/auth/sign-in/social?provider=google&callbackURL=/preferences"
           class="inline-flex items-center gap-3 bg-white text-stone-900 font-semibold px-7 py-3.5 rounded-xl hover:bg-stone-100 transition">
          <svg class="w-5 h-5" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
          Join Free with Google
        </a>
      </div>
    <% } %>
  </div>

  <div class="text-center text-sm text-stone-600 pb-8">
    A <a href="https://portal.place" class="text-brand-400 hover:text-brand-300">Portal.Place</a> product &middot; BC & Alberta Regional Intelligence
  </div>
</div>
