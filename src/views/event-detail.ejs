
<div class="max-w-2xl mx-auto">
  <a href="/events" class="text-xs text-stone-500 hover:text-stone-300 transition mb-6 inline-block">&larr; All Events</a>

  <!-- Event Header -->
  <div class="bg-stone-900 border border-stone-800 rounded-xl p-8 mb-6">
    <div class="flex items-start gap-6">
      <div class="bg-rose-500/10 border border-rose-500/20 rounded-xl p-4 text-center shrink-0 min-w-[60px]">
        <div class="text-rose-400 text-xs font-semibold uppercase"><%= new Date(meetup.event_date).toLocaleDateString('en-CA', { month: 'short' }) %></div>
        <div class="text-white font-bold text-2xl leading-none mt-1"><%= new Date(meetup.event_date).getDate() %></div>
      </div>
      <div>
        <h1 class="text-xl font-display font-bold mb-2"><%= meetup.title %></h1>
        <div class="flex flex-wrap items-center gap-3 text-sm text-stone-400 mb-3">
          <span>📍 <%= meetup.location %></span>
          <span>🕐 <%= new Date(meetup.event_date).toLocaleTimeString('en-CA', { hour: 'numeric', minute: '2-digit' }) %></span>
          <% if (meetup.rsvp_count > 0) { %><span><%= meetup.rsvp_count %> attending</span><% } %>
          <% if (meetup.capacity) { %><span><%= meetup.capacity - meetup.rsvp_count > 0 ? (meetup.capacity - meetup.rsvp_count) + ' spots left' : '⚠️ Full' %></span><% } %>
        </div>
        <% if (meetup.address) { %>
          <div class="text-xs text-stone-600 mb-3"><%= meetup.address %></div>
        <% } %>
      </div>
    </div>
    <% if (meetup.description) { %>
      <div class="mt-6 pt-6 border-t border-stone-800">
        <p class="text-stone-300 leading-relaxed"><%= meetup.description %></p>
      </div>
    <% } %>
  </div>

  <!-- RSVP Section -->
  <div class="bg-stone-900 border border-brand-800/40 rounded-xl p-8">
    <% if (success) { %>
      <div class="text-center py-4">
        <div class="text-4xl mb-3">🎉</div>
        <h2 class="font-semibold text-lg mb-2">You're in!</h2>
        <p class="text-stone-400 text-sm">You're on the list for <strong class="text-stone-200"><%= meetup.title %></strong>. We'll send a reminder closer to the date.</p>
        <a href="/events" class="inline-block mt-4 text-xs text-brand-400 hover:text-brand-300">← Browse other events</a>
      </div>
    <% } else if (alreadyRsvp) { %>
      <div class="text-center py-4">
        <div class="text-4xl mb-3">✅</div>
        <p class="text-stone-400 text-sm">You're already registered for this event.</p>
      </div>
    <% } else { %>
      <h2 class="font-semibold text-base mb-5">Reserve Your Spot</h2>
      <% if (error) { %>
        <div class="bg-red-500/10 text-red-400 text-sm px-4 py-3 rounded-lg mb-4"><%= error %></div>
      <% } %>
      <form method="POST" action="/events/<%= meetup.slug %>/rsvp" class="space-y-4">
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-medium mb-1.5 text-stone-400">Your Name</label>
            <input type="text" name="name" required placeholder="Mike Gilliland"
              class="w-full bg-stone-800 border border-stone-700 rounded-lg px-3 py-2.5 text-sm focus:border-brand-500 focus:outline-none transition">
          </div>
          <div>
            <label class="block text-xs font-medium mb-1.5 text-stone-400">Email</label>
            <input type="email" name="email" required placeholder="mike@example.com"
              class="w-full bg-stone-800 border border-stone-700 rounded-lg px-3 py-2.5 text-sm focus:border-brand-500 focus:outline-none transition">
          </div>
        </div>
        <div>
          <label class="block text-xs font-medium mb-1.5 text-stone-400">What brings you? <span class="text-stone-600">(optional)</span></label>
          <textarea name="note" rows="2" placeholder="e.g. Looking for land near Clearwater, building a homestead..."
            class="w-full bg-stone-800 border border-stone-700 rounded-lg px-3 py-2.5 text-sm focus:border-brand-500 focus:outline-none transition resize-none"></textarea>
        </div>
        <button type="submit" class="w-full bg-brand-500 hover:bg-brand-600 text-white font-semibold py-3 rounded-xl transition">
          Reserve My Spot →
        </button>
        <p class="text-xs text-stone-600 text-center">No spam. We'll only contact you about this event.</p>
      </form>
    <% } %>
  </div>
</div>
