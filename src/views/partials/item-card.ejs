<div class="bg-warm-dark border border-white/5 rounded-xl p-5 hover:border-white/10 transition-colors group">
  <div class="flex items-start gap-4">
    <div class="flex-1 min-w-0">
      <!-- Meta row -->
      <div class="flex flex-wrap items-center gap-2 mb-2.5">
        <span class="text-xs font-medium px-2.5 py-0.5 rounded-md shrink-0"
              :class="categoryBadgeClass(item.category)"
              x-text="categoryLabel(item.category)"></span>
        <span class="text-[11px] text-white/40 uppercase tracking-wider font-medium" x-text="item.region"></span>
        <template x-if="item.expires_at">
          <span class="text-xs text-amber font-medium flex items-center gap-1">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span x-text="formatDate(item.expires_at)"></span>
          </span>
        </template>
        <template x-if="item.pinned_at">
          <span class="text-xs text-amber font-medium flex items-center gap-1">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M5 5a2 2 0 012-2h6a2 2 0 012 2v14l-5-2.5L5 21V5z"/></svg>
            Pinned
          </span>
        </template>
        <template x-if="item.admin_vote === 1">
          <span class="text-[11px] font-semibold text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-1.5 py-0.5 rounded">+1</span>
        </template>
        <template x-if="item.admin_vote === -1">
          <span class="text-[11px] font-semibold text-red-400 bg-red-500/10 border border-red-500/20 px-1.5 py-0.5 rounded">-1</span>
        </template>
        <template x-if="item.save_count > 0">
          <span class="text-[11px] text-white/40 ml-auto flex items-center gap-1">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
            <span x-text="item.save_count"></span>
          </span>
        </template>
      </div>

      <!-- Title (goes to internal detail page) -->
      <a :href="'/feed/' + item.id"
        class="font-semibold text-[15px] text-white hover:text-amber transition-colors leading-snug block mb-2"
        x-text="item.title"></a>

      <!-- AI Summary -->
      <template x-if="item.summary">
        <p class="text-sm text-white/60 leading-relaxed mb-3 line-clamp-2" x-text="item.summary"></p>
      </template>

      <!-- AI Actionability chip -->
      <template x-if="item.ai_actionability">
        <div class="inline-flex items-center gap-1.5 text-xs text-amber bg-amber/10 border border-amber/20 px-2.5 py-1 rounded-lg font-medium mb-3">
          <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          <span x-text="item.ai_actionability"></span>
        </div>
      </template>

      <!-- Admin comment (if set) -->
      <template x-if="item.admin_comment">
        <div class="text-xs mt-1 mb-2 rounded-md px-2.5 py-1.5 bg-white/5 border border-white/10 text-white/60">
          <span class="font-medium text-white/80" x-text="item.admin_vote === 1 ? 'Why good:' : item.admin_vote === -1 ? 'Why bad:' : 'Note:'"></span>
          <span x-text="' ' + item.admin_comment"></span>
        </div>
      </template>

      <!-- Footer: source + date -->
      <div class="flex items-center gap-2 text-[11px] text-white/40">
        <span x-text="item.source_name || 'Community'"></span>
        <span class="w-1 h-1 rounded-full bg-white/20"></span>
        <span x-text="formatDate(item.collected_at)"></span>
      </div>
    </div>

    <!-- Right side: save + admin controls -->
    <div class="flex flex-col items-end gap-2 shrink-0 pt-0.5">
      <!-- Save button (all users) -->
      <button @click="toggleSave(item.id)"
        class="p-2 rounded-lg hover:bg-white/5 transition-colors"
        :class="savedIds.has(item.id) ? 'text-amber' : 'text-white/30 hover:text-white/60'"
        :aria-label="savedIds.has(item.id) ? 'Remove from watchlist' : 'Save to watchlist'">
        <svg class="w-4 h-4" :fill="savedIds.has(item.id) ? 'currentColor' : 'none'" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/>
        </svg>
      </button>

      <% if (user && user.role === 'admin') { %>
        <!-- Admin controls (admin only): upvote / downvote / pin -->
        <div x-data="{ showComment: false, pendingVote: 0, comment: item.admin_comment || '' }" class="flex flex-col items-end gap-1.5">
          <div class="flex items-center gap-0.5">
            <!-- Pin toggle -->
            <button @click="fetch('/admin/items/' + item.id + '/pin', { method: 'POST' }).then(() => { item.pinned_at = item.pinned_at ? null : new Date().toISOString() })"
              class="p-1.5 rounded-md transition-colors"
              :class="item.pinned_at ? 'text-amber bg-amber/10' : 'text-white/30 hover:text-amber hover:bg-white/5'"
              title="Pin to top">
              <svg class="w-3.5 h-3.5" :fill="item.pinned_at ? 'currentColor' : 'none'" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/></svg>
            </button>
            <!-- Upvote -->
            <button @click="pendingVote = 1; showComment = true; $nextTick(() => $refs.commentBox && $refs.commentBox.focus())"
              class="p-1.5 rounded-md transition-colors"
              :class="item.admin_vote === 1 ? 'text-emerald-400 bg-emerald-500/10' : 'text-white/30 hover:text-emerald-400 hover:bg-emerald-500/10'"
              title="Upvote (requires comment)">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5"/></svg>
            </button>
            <!-- Downvote -->
            <button @click="pendingVote = -1; showComment = true; $nextTick(() => $refs.commentBox && $refs.commentBox.focus())"
              class="p-1.5 rounded-md transition-colors"
              :class="item.admin_vote === -1 ? 'text-red-400 bg-red-500/10' : 'text-white/30 hover:text-red-400 hover:bg-red-500/10'"
              title="Downvote (requires comment)">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14H5.236a2 2 0 01-1.789-2.894l3.5-7A2 2 0 018.736 3h4.018c.163 0 .326.02.485.06L17 4m-7 10v5a2 2 0 002 2h.095c.5 0 .905-.405.905-.905 0-.714.211-1.412.608-2.006L17 13V4m-7 10h2M17 4h2.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0116.264 15H14"/></svg>
            </button>
          </div>

          <!-- Re-enrich with feedback button -->
          <div x-data="{ showReenrich: false, reenrichNote: '', reenriching: false, done: false }" class="relative">
            <button @click="showReenrich = !showReenrich"
              class="p-1.5 rounded-md transition-colors text-white/30 hover:text-sky-400 hover:bg-sky-500/10"
              title="Re-generate with feedback">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
            </button>
            <div x-show="showReenrich" style="display:none" class="absolute right-0 top-8 z-10 w-64 bg-warm-dark border border-white/10 rounded-lg p-2.5 shadow-xl">
              <p class="text-[10px] text-sky-400 font-medium mb-1.5">Re-generate with feedback</p>
              <textarea x-model="reenrichNote" rows="2" placeholder="What should change? (optional)"
                class="w-full bg-white/5 border border-white/10 rounded-md px-2 py-1.5 text-xs text-white placeholder-white/30 focus:border-sky-500/50 focus:outline-none transition-colors resize-none"></textarea>
              <div class="flex gap-1.5 mt-2">
                <button @click="
                  reenriching = true;
                  fetch('/admin/items/' + item.id + '/reenrich', {
                    method: 'POST',
                    headers: {'Content-Type':'application/x-www-form-urlencoded'},
                    body: 'feedback=' + encodeURIComponent(reenrichNote)
                  }).then(r => r.json()).then(d => {
                    reenriching = false;
                    if (d.ok) { done = true; showReenrich = false; setTimeout(() => location.reload(), 800); }
                  });"
                  :disabled="reenriching"
                  class="flex-1 text-xs py-1.5 rounded-md bg-sky-500/20 text-sky-300 hover:bg-sky-500/30 font-medium transition disabled:opacity-50">
                  <span x-show="!reenriching">Regenerate</span>
                  <span x-show="reenriching">Working…</span>
                </button>
                <button @click="showReenrich = false" class="text-xs px-2 py-1.5 text-white/40 hover:text-white/60 hover:bg-white/5 rounded-md transition">Cancel</button>
              </div>
            </div>
          </div>

          <!-- Comment box — appears after clicking up/down -->
          <div x-show="showComment" style="display:none" class="w-64 bg-warm-dark border border-white/10 rounded-lg p-2.5 mt-0.5">
            <p class="text-[10px] mb-1.5 font-medium" :class="pendingVote === 1 ? 'text-emerald-400' : 'text-red-400'" x-text="pendingVote === 1 ? 'Why is this good?' : 'Why is this bad?'"></p>
            <textarea x-ref="commentBox" x-model="comment" rows="2" placeholder="Required — trains the AI"
              class="w-full bg-white/5 border border-white/10 rounded-md px-2 py-1.5 text-xs text-white placeholder-white/30 focus:border-amber/50 focus:ring-1 focus:ring-amber/30 focus:outline-none transition-colors resize-none"></textarea>
            <div class="flex gap-1.5 mt-2">
              <button @click="
                if (!comment.trim()) return;
                fetch('/admin/items/' + item.id + '/vote', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                  body: 'vote=' + pendingVote + '&comment=' + encodeURIComponent(comment)
                }).then(() => { item.admin_vote = pendingVote; item.admin_comment = comment; showComment = false; });"
                :disabled="!comment.trim()"
                class="flex-1 text-xs py-1.5 rounded-md font-medium transition-colors disabled:opacity-30 disabled:cursor-not-allowed"
                :class="pendingVote === 1 ? 'bg-emerald-500/20 text-emerald-300 hover:bg-emerald-500/30' : 'bg-red-500/20 text-red-300 hover:bg-red-500/30'"
                x-text="pendingVote === 1 ? 'Submit upvote' : 'Submit downvote'">
              </button>
              <button @click="showComment = false"
                class="text-xs px-2 py-1.5 rounded-md text-white/40 hover:text-white/60 hover:bg-white/5 transition-colors">
                Cancel
              </button>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</div>
