
<div class="max-w-2xl mx-auto">
  <a href="/discussions" class="text-xs text-stone-500 hover:text-stone-300 transition-colors mb-6 inline-flex items-center gap-1.5">
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
    All Discussions
  </a>

  <h1 class="text-2xl font-display font-bold mb-2">Start a Discussion</h1>
  <p class="text-sm text-stone-500 mb-6">Ask a question, share a project, or seek advice from the community.</p>

  <form method="POST" action="/discussions" class="space-y-5">
    <div>
      <label class="block text-sm font-medium mb-1.5">Title</label>
      <input type="text" name="title" required maxlength="300" placeholder="What's on your mind?"
        class="w-full bg-stone-900/60 border border-stone-700/60 rounded-xl px-3.5 py-2.5 text-sm focus:border-brand-500/50 focus:ring-1 focus:ring-brand-500/30 focus:outline-none transition-colors">
    </div>

    <div>
      <label class="block text-sm font-medium mb-1.5">Body <span class="text-stone-600">(optional)</span></label>
      <textarea name="body" rows="6" maxlength="5000" placeholder="Add details, context, or questions..."
        class="w-full bg-stone-900/60 border border-stone-700/60 rounded-xl px-3.5 py-2.5 text-sm focus:border-brand-500/50 focus:ring-1 focus:ring-brand-500/30 focus:outline-none transition-colors resize-none"></textarea>
    </div>

    <div>
      <label class="block text-sm font-medium mb-2">Category <span class="text-stone-600">(optional)</span></label>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
        <% categories.forEach(function(cat) { %>
          <label class="cursor-pointer">
            <input type="radio" name="category" value="<%= cat.slug %>" class="hidden peer">
            <div class="p-3 rounded-xl border border-stone-800/60 text-center transition-colors peer-checked:border-brand-500/50 peer-checked:bg-brand-500/10 hover:border-stone-700/60">
              <div class="text-lg mb-0.5"><%= cat.icon %></div>
              <div class="text-xs font-medium"><%= cat.label %></div>
            </div>
          </label>
        <% }) %>
      </div>
    </div>

    <button type="submit" class="bg-brand-500 hover:bg-brand-600 text-white font-medium px-6 py-3.5 rounded-xl transition-colors w-full sm:w-auto active:scale-[0.98] shadow-lg shadow-brand-500/20 hover:shadow-brand-500/30">
      Post Discussion
    </button>
  </form>
</div>
