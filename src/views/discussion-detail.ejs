
<div class="max-w-3xl mx-auto">
  <a href="/discussions" class="text-xs text-stone-500 hover:text-stone-300 transition-colors mb-6 inline-flex items-center gap-1.5">
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
    All Discussions
  </a>

  <article class="bg-stone-900/60 border border-stone-800/60 rounded-2xl p-6 sm:p-8 mb-8">
    <div class="flex items-start gap-4 mb-5">
      <% if (discussion.author_image) { %>
        <img src="<%= discussion.author_image %>" alt="" class="w-12 h-12 rounded-full ring-1 ring-stone-800 shrink-0">
      <% } else { %>
        <div class="w-12 h-12 rounded-full bg-brand-800 flex items-center justify-center text-brand-300 text-lg font-semibold ring-1 ring-stone-800 shrink-0"><%= (discussion.author_name || '?').charAt(0).toUpperCase() %></div>
      <% } %>
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2 mb-1.5 flex-wrap">
          <span class="text-sm font-medium text-stone-200"><%= discussion.author_name || 'Anonymous' %></span>
          <span class="text-xs text-stone-600">&middot;</span>
          <span class="text-xs text-stone-500"><%= new Date(discussion.created_at).toLocaleDateString('en-CA', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
          <% if (discussion.pinned) { %>
            <span class="text-xs text-amber-400 font-medium flex items-center gap-1">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M5 5a2 2 0 012-2h6a2 2 0 012 2v14l-5-2.5L5 21V5z"/></svg>
              Pinned
            </span>
          <% } %>
          <% if (discussion.category && categoryData[discussion.category]) { %>
            <span class="text-xs font-medium px-2 py-0.5 rounded-md <%= categoryData[discussion.category].badge %>"><%= categoryData[discussion.category].icon %> <%= categoryData[discussion.category].label %></span>
          <% } %>
        </div>
      </div>
    </div>

    <h1 class="text-2xl sm:text-3xl font-display font-bold text-stone-50 mb-4 leading-tight"><%= discussion.title %></h1>

    <% if (discussion.body) { %>
      <div class="text-stone-300 leading-relaxed whitespace-pre-line"><%= discussion.body %></div>
    <% } %>

    <% if (discussion.locked) { %>
      <div class="mt-5 pt-5 border-t border-stone-800/60 inline-flex items-center gap-2 text-xs text-stone-500">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
        This discussion is locked. No new comments can be posted.
      </div>
    <% } %>
  </article>

  <% if (!discussion.locked) { %>
    <%- include('./partials/comment-thread.ejs', {
      targetType: 'discussion',
      targetId: discussion.id,
      comments: comments,
      user: user,
      postUrl: '/discussions/' + discussion.id + '/comments',
      callbackUrl: '/discussions/' + discussion.id
    }) %>
  <% } %>
</div>
