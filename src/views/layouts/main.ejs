<!DOCTYPE html>
<html lang="en" class="bg-stone-950 text-stone-100">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %>Portal.Place Intel</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Marcellus+SC&family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Montserrat', 'system-ui', 'sans-serif'],
            display: ['"Marcellus SC"', 'serif'],
          },
          colors: {
            brand: {
              50:  '#eef2ff',
              100: '#e0e7ff',
              200: '#c7d2fe',
              300: '#a5b4fc',
              400: '#6B6BAA',
              500: '#4D4DC0',
              600: '#38387F',
              700: '#2E2E6B',
              800: '#1F1F4E',
              900: '#181835',
            },
            accent: {
              300: '#f4a67a',
              400: '#EA824E',
              500: '#9F3C2D',
              600: '#8A3326',
              700: '#6E2A1F',
            },
          }
        }
      }
    }
  </script>
  <style>
    [x-cloak] { display: none !important; }
    .font-display { font-family: 'Marcellus SC', serif; }
    /* Focus ring for keyboard navigation */
    :focus-visible { outline: 2px solid #6B6BAA; outline-offset: 2px; border-radius: 4px; }
    /* Smooth transitions */
    * { -webkit-tap-highlight-color: transparent; }
    /* Active nav indicator */
    .nav-active { color: #e7e5e4; position: relative; }
    .nav-active::after { content: ''; position: absolute; bottom: -4px; left: 0; right: 0; height: 2px; background: #4D4DC0; border-radius: 1px; }
  </style>
</head>
<body class="min-h-screen flex flex-col">
  <% if (typeof user !== 'undefined' && user) { %>
  <nav x-data="{ mobileOpen: false }" class="border-b border-stone-800/80 bg-stone-950/80 backdrop-blur-md sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
      <div class="flex items-center gap-8">
        <a href="/feed" class="font-semibold text-brand-400 tracking-tight text-base">Portal.Place Intel</a>
        <div class="hidden md:flex items-center gap-1 text-sm">
          <%
            var navItems = [
              { href: '/feed', label: 'Feed' },
              { href: '/discussions', label: 'Discuss' },
              { href: '/events', label: 'Events' },
              { href: '/calls', label: 'Calls' },
              { href: '/submit', label: 'Submit' },
              { href: '/feed/watchlist', label: 'Watchlist' },
              { href: '/profile/edit', label: 'Profile' },
            ];
            var currentPath = typeof currentUrl !== 'undefined' ? currentUrl : '';
          %>
          <% navItems.forEach(function(item) { %>
            <a href="<%= item.href %>" class="px-3 py-1.5 rounded-lg text-stone-400 hover:text-stone-100 hover:bg-stone-800/60 transition-colors"><%= item.label %></a>
          <% }) %>
          <% if (user.role === 'admin') { %>
            <a href="/admin" class="px-3 py-1.5 rounded-lg text-accent-400 hover:text-accent-300 hover:bg-accent-500/10 transition-colors">Admin</a>
          <% } %>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <a href="/preferences" class="hidden sm:block text-sm text-stone-500 hover:text-stone-200 transition-colors p-1.5">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        </a>
        <div class="hidden sm:flex items-center gap-2">
          <% if (user.image) { %>
            <img src="<%= user.image %>" alt="" class="w-7 h-7 rounded-full ring-1 ring-stone-800">
          <% } else { %>
            <div class="w-7 h-7 rounded-full bg-brand-800 flex items-center justify-center text-brand-400 text-xs font-semibold ring-1 ring-stone-800"><%= user.name?.charAt(0)?.toUpperCase() || '?' %></div>
          <% } %>
        </div>
        <!-- Mobile hamburger -->
        <button @click="mobileOpen = !mobileOpen" class="md:hidden p-2 -mr-2 rounded-lg hover:bg-stone-800/60 transition-colors" aria-label="Toggle menu">
          <svg x-show="!mobileOpen" class="w-5 h-5 text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          <svg x-show="mobileOpen" x-cloak class="w-5 h-5 text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
    </div>
    <!-- Mobile menu -->
    <div x-show="mobileOpen" x-cloak x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 -translate-y-2" x-transition:enter-end="opacity-100 translate-y-0" x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0 -translate-y-2"
      class="md:hidden border-t border-stone-800/80 bg-stone-950/95 backdrop-blur-md px-4 pb-4 pt-2">
      <div class="flex flex-col gap-1">
        <% navItems.forEach(function(item) { %>
          <a href="<%= item.href %>" class="px-3 py-2.5 rounded-lg text-sm text-stone-300 hover:text-stone-100 hover:bg-stone-800/60 transition-colors"><%= item.label %></a>
        <% }) %>
        <% if (user.role === 'admin') { %>
          <a href="/admin" class="px-3 py-2.5 rounded-lg text-sm text-accent-400 hover:text-accent-300 hover:bg-accent-500/10 transition-colors">Admin</a>
        <% } %>
        <div class="border-t border-stone-800/60 mt-2 pt-2 flex items-center gap-3 px-3">
          <a href="/preferences" class="text-sm text-stone-500 hover:text-stone-200 transition-colors">Preferences</a>
          <span class="text-sm text-stone-600"><%= user.name %></span>
        </div>
      </div>
    </div>
  </nav>
  <% } %>

  <main class="max-w-6xl mx-auto px-4 sm:px-6 py-8 flex-1 w-full">
    <%- body %>
  </main>

  <footer class="border-t border-stone-800/60 mt-auto">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-stone-600">
      <span>Portal.Place Intel &middot; BC &amp; Alberta Regional Intelligence</span>
      <div class="flex items-center gap-4">
        <a href="https://portal.place" class="hover:text-stone-400 transition-colors">Portal.Place</a>
        <a href="/archive" class="hover:text-stone-400 transition-colors">Newsletter Archive</a>
      </div>
    </div>
  </footer>
</body>
</html>
