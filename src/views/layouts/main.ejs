<!DOCTYPE html>
<html lang="en" class="bg-warm-dark text-white">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %>Portal.Place Intel</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Marcellus+SC&family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Montserrat', 'system-ui', 'sans-serif'],
            display: ['"Marcellus SC"', 'serif'],
          },
          colors: {
            // Matches portal.place palette exactly
            'warm-dark': '#1a1720',
            'warm-darker': '#0f0e12',
            'indigo': '#38387f',
            'terracotta': '#af695e',
            'mauve': '#73516f',
            'amber': '#ea824e',
            'cream': '#faf8f4',
            'off-white': '#f2ede8',
            'ink': '#1a1720',
            // Legacy brand/accent aliases for existing components
            brand: {
              50:  '#eef2ff',
              100: '#e0e7ff',
              200: '#c7d2fe',
              300: '#a5b4fc',
              400: '#8080c4',
              500: '#4D4DC0',
              600: '#38387f',
              700: '#2E2E6B',
              800: '#1F1F4E',
              900: '#181835',
            },
            accent: {
              300: '#f4a67a',
              400: '#ea824e',
              500: '#af695e',
              600: '#73516f',
              700: '#5a3f56',
            },
          }
        }
      }
    }
  </script>
  <style>
    [x-cloak] { display: none !important; }
    .font-display { font-family: 'Marcellus SC', serif; }
    :focus-visible { outline: 2px solid #ea824e; outline-offset: 2px; border-radius: 4px; }
    * { -webkit-tap-highlight-color: transparent; }
    /* Layered dark background with subtle warmth */
    body { background: #1a1720; color: #ffffff; }
  </style>
</head>
<body class="min-h-screen flex flex-col">
  <% if (typeof user !== 'undefined' && user) { %>
  <header x-data="{ mobileOpen: false }" class="fixed top-0 z-50 w-full bg-warm-dark/70 backdrop-blur-md border-b border-white/5">
    <div class="mx-auto flex max-w-[1400px] items-center justify-between px-6 py-5 lg:px-16">
      <!-- Logo -->
      <a href="<%= user.role === 'admin' ? '/feed' : '/' %>" class="shrink-0 flex items-center gap-2.5 group">
        <span class="text-[0.95rem] font-semibold tracking-tight text-white group-hover:text-amber transition-colors">Portal.Place Intel</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1">
        <%
          var navItems = user.role === 'admin' ? [
            { href: '/feed', label: 'Feed' },
            { href: '/discussions', label: 'Discuss' },
            { href: '/events', label: 'Events' },
            { href: '/calls', label: 'Calls' },
            { href: '/submit', label: 'Submit' },
            { href: '/feed/watchlist', label: 'Watchlist' },
            { href: '/profile/edit', label: 'Profile' },
          ] : [];
        %>
        <% navItems.forEach(function(item) { %>
          <a href="<%= item.href %>" class="rounded-md px-4 py-2 text-sm transition-colors hover:text-white text-white/60"><%= item.label %></a>
        <% }) %>
        <% if (user.role === 'admin') { %>
          <a href="/admin" class="rounded-md px-4 py-2 text-sm transition-colors hover:text-amber text-amber/70">Admin</a>
        <% } %>
      </nav>
      <!-- Right side: avatar dropdown + mobile hamburger -->
      <div class="flex items-center gap-3">
        <div x-data="{ open: false }" class="hidden lg:flex items-center relative">
          <button @click="open = !open" @click.away="open = false" class="flex items-center gap-2 rounded-full p-1 hover:bg-white/5 transition-colors" aria-label="Account menu">
            <% if (user.image) { %>
              <img src="<%= user.image %>" alt="" class="w-8 h-8 rounded-full ring-1 ring-white/10">
            <% } else { %>
              <div class="w-8 h-8 rounded-full bg-amber/20 flex items-center justify-center text-amber text-xs font-semibold ring-1 ring-white/10"><%= user.name?.charAt(0)?.toUpperCase() || '?' %></div>
            <% } %>
          </button>
          <div x-show="open" x-cloak x-transition class="absolute right-0 top-full mt-3 w-60 bg-warm-dark border border-white/10 rounded-xl shadow-2xl shadow-black/50 py-1.5 z-50">
            <div class="px-4 py-3 border-b border-white/5">
              <div class="text-sm font-medium text-white truncate"><%= user.name %></div>
              <div class="text-xs text-white/50 truncate"><%= user.email %></div>
              <% if (user.role === 'admin') { %>
                <div class="text-[10px] uppercase tracking-widest font-semibold text-amber mt-1.5">Admin</div>
              <% } %>
            </div>
            <a href="/profile/edit" class="block px-4 py-2 text-sm text-white/70 hover:bg-white/5 hover:text-white transition-colors">Profile</a>
            <a href="/preferences" class="block px-4 py-2 text-sm text-white/70 hover:bg-white/5 hover:text-white transition-colors">Preferences</a>
            <% if (user.role === 'admin') { %>
              <a href="/admin/users" class="block px-4 py-2 text-sm text-white/70 hover:bg-white/5 hover:text-white transition-colors">Manage Users</a>
            <% } %>
            <div class="border-t border-white/5 my-1"></div>
            <button type="button" onclick="signOut()" class="w-full text-left px-4 py-2 text-sm text-white/70 hover:bg-white/5 hover:text-amber transition-colors flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
              Sign out
            </button>
          </div>
        </div>
        <!-- Mobile hamburger -->
        <button @click="mobileOpen = !mobileOpen" class="lg:hidden text-white/70 hover:text-white transition-colors cursor-pointer p-1" aria-label="Toggle menu">
          <svg x-show="!mobileOpen" xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 256 256"><path d="M222,128a6,6,0,0,1-6,6H40a6,6,0,0,1,0-12H216A6,6,0,0,1,222,128ZM40,70H216a6,6,0,0,0,0-12H40a6,6,0,0,0,0,12ZM216,186H40a6,6,0,0,0,0,12H216a6,6,0,0,0,0-12Z"></path></svg>
          <svg x-show="mobileOpen" x-cloak class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div x-show="mobileOpen" x-cloak x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 -translate-y-2" x-transition:enter-end="opacity-100 translate-y-0" x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0 -translate-y-2"
      class="lg:hidden border-t border-white/5 bg-warm-dark/95 backdrop-blur-md px-6 pb-6 pt-4">
      <div class="flex flex-col gap-1">
        <% navItems.forEach(function(item) { %>
          <a href="<%= item.href %>" class="rounded-md px-4 py-2.5 text-sm text-white/70 hover:text-white hover:bg-white/5 transition-colors"><%= item.label %></a>
        <% }) %>
        <% if (user.role === 'admin') { %>
          <a href="/admin" class="rounded-md px-4 py-2.5 text-sm text-amber/70 hover:text-amber hover:bg-amber/10 transition-colors">Admin</a>
        <% } %>
        <div class="border-t border-white/5 mt-3 pt-3 flex flex-col gap-1">
          <a href="/preferences" class="rounded-md px-4 py-2.5 text-sm text-white/60 hover:text-white hover:bg-white/5 transition-colors">Preferences</a>
          <% if (user.role === 'admin') { %>
            <a href="/admin/users" class="rounded-md px-4 py-2.5 text-sm text-white/60 hover:text-white hover:bg-white/5 transition-colors">Manage Users</a>
          <% } %>
          <button type="button" onclick="signOut()" class="w-full text-left rounded-md px-4 py-2.5 text-sm text-white/60 hover:text-amber hover:bg-white/5 transition-colors">Sign out</button>
          <div class="text-xs text-white/40 px-4 pt-2 truncate"><%= user.email %></div>
        </div>
      </div>
    </div>
  </header>
  <% } %>

  <main class="<%= typeof user !== 'undefined' && user ? 'pt-24' : '' %> max-w-6xl mx-auto px-4 sm:px-6 py-8 flex-1 w-full">
    <%- body %>
  </main>

  <script>
    async function signOut() {
      try {
        await fetch('/api/auth/sign-out', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: '{}'
        });
        window.location.href = '/';
      } catch (e) {
        console.error('Sign out failed', e);
        window.location.href = '/';
      }
    }
  </script>

  <footer class="border-t border-white/5 mt-auto">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-16 py-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-white/40">
      <span>Portal.Place Intel &middot; Regional Intelligence</span>
      <div class="flex items-center gap-5">
        <a href="https://portal.place" class="hover:text-amber transition-colors">Portal.Place</a>
        <a href="/archive" class="hover:text-amber transition-colors">Newsletter Archive</a>
      </div>
    </div>
  </footer>
</body>
</html>
