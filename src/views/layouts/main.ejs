<!DOCTYPE html>
<html lang="en" class="bg-stone-950 text-stone-100">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %>Portal.Place Intel</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Marcellus+SC&family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Montserrat', 'system-ui', 'sans-serif'],
            display: ['"Marcellus SC"', 'serif'],
          },
          colors: {
            brand: {
              50:  '#eef2ff',
              100: '#e0e7ff',
              200: '#c7d2fe',
              300: '#a5b4fc',
              400: '#6B6BAA',
              500: '#4D4DC0',
              600: '#38387F',
              700: '#2E2E6B',
              800: '#1F1F4E',
              900: '#181835',
            },
            accent: {
              300: '#f4a67a',
              400: '#EA824E',
              500: '#9F3C2D',
              600: '#8A3326',
              700: '#6E2A1F',
            },
          }
        }
      }
    }
  </script>
  <style>
    [x-cloak] { display: none !important; }
    .font-display { font-family: 'Marcellus SC', serif; }
  </style>
</head>
<body class="min-h-screen">
  <% if (typeof user !== 'undefined' && user) { %>
  <nav class="border-b border-stone-800 bg-stone-900/50 backdrop-blur-sm sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between">
      <div class="flex items-center gap-6">
        <a href="/feed" class="font-semibold text-brand-400 tracking-tight">Portal.Place Intel</a>
        <div class="hidden sm:flex items-center gap-4 text-sm text-stone-400">
          <a href="/feed" class="hover:text-stone-100 transition">Feed</a>
          <a href="/events" class="hover:text-stone-100 transition">Events</a>
          <a href="/calls" class="hover:text-stone-100 transition">Calls</a>
          <a href="/submit" class="hover:text-stone-100 transition">Submit</a>
          <a href="/feed/watchlist" class="hover:text-stone-100 transition">Watchlist</a>
          <a href="/profile/edit" class="hover:text-stone-100 transition">Profile</a>
          <% if (user.role === 'admin') { %>
          <a href="/admin" class="text-accent-400 hover:text-accent-300 transition">Admin</a>
          <% } %>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <a href="/preferences" class="text-sm text-stone-400 hover:text-stone-100 transition">Preferences</a>
        <span class="text-sm text-stone-500"><%= user.name %></span>
      </div>
    </div>
  </nav>
  <% } %>

  <main class="max-w-6xl mx-auto px-4 py-8">
    <%- body %>
  </main>

  <footer class="border-t border-stone-800 mt-16">
    <div class="max-w-6xl mx-auto px-4 py-8 text-center text-sm text-stone-600">
      Portal.Place Intel &middot; BC &amp; Alberta Regional Intelligence
    </div>
  </footer>
</body>
</html>
