
<div class="max-w-4xl mx-auto">
  <a href="/feed" class="text-xs text-white/40 hover:text-white transition-colors mb-6 inline-flex items-center gap-1.5">
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
    Back to Feed
  </a>

  <% if (item.category === 'land') { %>
    <%- include('./item-detail-land.ejs') %>
  <% } else { %>
    <%- include('./item-detail-generic.ejs') %>
  <% } %>

  <!-- Comments (shared across all categories) -->
  <div class="mt-10">
    <%- include('./partials/comment-thread.ejs', {
      targetType: 'item',
      targetId: item.id,
      comments: comments,
      user: user,
      postUrl: '/feed/' + item.id + '/comments',
      callbackUrl: '/feed/' + item.id
    }) %>
  </div>
</div>
