
<div class="max-w-2xl mx-auto" x-data="{ selectedCategory: '', selectedType: '' }">
  <h1 class="text-2xl font-display font-bold mb-2">Submit to Intel</h1>
  <p class="text-sm text-stone-400 mb-6">Share a project, listing, event, deal, or tip. All submissions are reviewed before appearing on the feed.</p>

  <% if (success) { %>
    <div class="bg-brand-400/10 text-brand-400 text-sm px-4 py-3 rounded-lg mb-6">
      Submitted! We'll review it shortly.
    </div>
  <% } %>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="bg-red-400/10 text-red-400 text-sm px-4 py-3 rounded-lg mb-6"><%= error %></div>
  <% } %>

  <form method="POST" action="/submit" class="space-y-6">
    <!-- Type Selection Grid -->
    <div>
      <label class="block text-sm font-medium mb-2">What are you sharing?</label>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        <% [
          { value: 'deal', icon: '🤝', label: 'Deal', desc: 'Partnership or investment' },
          { value: 'project', icon: '🏗️', label: 'Project', desc: 'Something you\'re building' },
          { value: 'listing', icon: '📋', label: 'Listing', desc: 'For sale or wanted' },
          { value: 'event', icon: '📅', label: 'Event', desc: 'Workshop or meetup' },
          { value: 'source', icon: '🔗', label: 'Source', desc: 'Website to track' },
          { value: 'tip', icon: '💡', label: 'Tip', desc: 'Info or lead' },
        ].forEach(function(t) { %>
          <label class="cursor-pointer">
            <input type="radio" name="type" value="<%= t.value %>" class="hidden peer" x-model="selectedType" required>
            <div class="p-4 rounded-lg border text-center transition peer-checked:border-brand-500 peer-checked:bg-brand-500/10 border-stone-800 hover:border-stone-700">
              <div class="text-2xl mb-1"><%= t.icon %></div>
              <div class="text-sm font-medium"><%= t.label %></div>
              <div class="text-xs text-stone-500 mt-0.5"><%= t.desc %></div>
            </div>
          </label>
        <% }) %>
      </div>
    </div>

    <div>
      <label class="block text-sm font-medium mb-1">Title</label>
      <input type="text" name="title" required placeholder="Brief, descriptive title"
        class="w-full bg-stone-900/60 border border-stone-700/60 rounded-xl px-3.5 py-2.5 text-sm focus:border-brand-500/50 focus:ring-1 focus:ring-brand-500/30 transition-colors">
    </div>

    <div>
      <label class="block text-sm font-medium mb-1">Description</label>
      <textarea name="description" rows="4" placeholder="What's this about? Be specific."
        class="w-full bg-stone-900/60 border border-stone-700/60 rounded-xl px-3.5 py-2.5 text-sm focus:border-brand-500/50 focus:ring-1 focus:ring-brand-500/30 transition-colors"></textarea>
    </div>

    <div>
      <label class="block text-sm font-medium mb-1">URL (optional)</label>
      <input type="url" name="url" placeholder="https://..."
        class="w-full bg-stone-900/60 border border-stone-700/60 rounded-xl px-3.5 py-2.5 text-sm focus:border-brand-500/50 focus:ring-1 focus:ring-brand-500/30 transition-colors">
    </div>

    <!-- Category Selection Grid -->
    <div>
      <label class="block text-sm font-medium mb-2">Category</label>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        <% categories.forEach(function(cat) { %>
          <label class="cursor-pointer">
            <input type="radio" name="category" value="<%= cat.slug %>" class="hidden peer" x-model="selectedCategory" required>
            <div class="p-3 rounded-lg border text-center transition peer-checked:border-brand-500 peer-checked:bg-brand-500/10 border-stone-800 hover:border-stone-700">
              <div class="text-xl mb-0.5"><%= cat.icon %></div>
              <div class="text-xs font-medium"><%= cat.label %></div>
            </div>
          </label>
        <% }) %>
      </div>
    </div>

    <!-- Region Selection -->
    <div>
      <label class="block text-sm font-medium mb-2">Region</label>
      <div class="flex gap-3">
        <% regions.forEach(function(r, i) { %>
          <label class="cursor-pointer">
            <input type="radio" name="region" value="<%= r.slug %>" class="hidden peer" <%= i === 0 ? 'checked' : '' %>>
            <div class="px-4 py-2 rounded-lg border text-center text-sm transition peer-checked:border-brand-500 peer-checked:bg-brand-500/10 border-stone-800 hover:border-stone-700">
              <%= r.label %>
            </div>
          </label>
        <% }) %>
      </div>
    </div>

    <div>
      <label class="block text-sm font-medium mb-1">Expiry Date (optional)</label>
      <input type="date" name="expires_at"
        class="w-full bg-stone-900/60 border border-stone-700/60 rounded-xl px-3.5 py-2.5 text-sm focus:border-brand-500/50 focus:ring-1 focus:ring-brand-500/30 transition-colors">
      <p class="text-xs text-stone-500 mt-1">For grants, events, or listings with a deadline.</p>
    </div>

    <button type="submit" class="bg-brand-500 hover:bg-brand-600 text-white font-medium px-6 py-3.5 rounded-xl transition-colors w-full active:scale-[0.98] shadow-lg shadow-brand-500/20 hover:shadow-brand-500/30">
      Submit for Review
    </button>
  </form>
</div>
