
<div class="max-w-4xl mx-auto">
  <h1 class="text-2xl font-display font-bold mb-2">Watchlist</h1>
  <p class="text-sm text-stone-400 mb-6">Items you've saved from the Intel Feed.</p>

  <% if (items.length === 0) { %>
    <div class="text-center py-16 text-stone-500">
      <div class="text-4xl mb-4">📌</div>
      <p class="mb-2">No saved items yet.</p>
      <a href="/feed" class="text-brand-400 hover:text-brand-300 text-sm">Browse the Intel Feed &rarr;</a>
    </div>
  <% } else { %>
    <% const catColors = { land: 'bg-emerald-500/10 text-emerald-400', grants: 'bg-amber-500/10 text-amber-400', operators: 'bg-sky-500/10 text-sky-400', jobs: 'bg-violet-500/10 text-violet-400', events: 'bg-rose-500/10 text-rose-400', infrastructure: 'bg-orange-500/10 text-orange-400' }; %>
    <div class="space-y-3">
      <% items.forEach(function(item) { %>
        <div class="bg-stone-900 border border-stone-800 rounded-lg p-5 hover:border-stone-700 transition">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1.5">
                <span class="text-xs font-medium px-2 py-0.5 rounded-full <%= catColors[item.category] || 'bg-stone-800 text-stone-400' %>"><%= categories.find(c => c.slug === item.category)?.icon || '' %> <%= categories.find(c => c.slug === item.category)?.label || item.category %></span>
                <span class="text-xs text-stone-600"><%= item.region.toUpperCase() %></span>
              </div>
              <div class="font-medium text-sm"><%= item.title %></div>
              <div class="text-xs text-stone-400 mt-1.5 leading-relaxed"><%= item.summary %></div>
              <div class="text-xs text-stone-500 mt-2">
                <%= item.source_name || 'User submitted' %> &middot;
                Saved <%= new Date(item.saved_at).toLocaleDateString('en-CA', { month: 'short', day: 'numeric' }) %>
              </div>
            </div>
            <a href="<%= item.url %>" target="_blank" class="text-xs text-accent-400 hover:text-accent-300 shrink-0 font-medium">View &rarr;</a>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
