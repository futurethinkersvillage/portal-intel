
<div class="max-w-4xl mx-auto">
  <h1 class="text-2xl font-bold mb-2">Watchlist</h1>
  <p class="text-sm text-stone-400 mb-6">Items you've saved from the Intel Feed.</p>

  <% if (items.length === 0) { %>
    <div class="text-center py-16 text-stone-500">
      <p class="mb-2">No saved items yet.</p>
      <a href="/feed" class="text-brand-400 hover:text-brand-300 text-sm">Browse the Intel Feed &rarr;</a>
    </div>
  <% } else { %>
    <div class="space-y-2">
      <% items.forEach(function(item) { %>
        <div class="bg-stone-900 border border-stone-800 rounded-lg p-4">
          <div class="flex items-start justify-between gap-4">
            <div>
              <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-stone-800 text-stone-400"><%= categories.find(c => c.slug === item.category)?.label || item.category %></span>
              <span class="text-xs text-stone-600 ml-1"><%= item.region.toUpperCase() %></span>
              <div class="font-medium text-sm mt-1"><%= item.title %></div>
              <div class="text-xs text-stone-400 mt-1"><%= item.summary %></div>
              <div class="text-xs text-stone-500 mt-2">
                <%= item.source_name || 'User submitted' %> &middot;
                Saved <%= new Date(item.saved_at).toLocaleDateString('en-CA', { month: 'short', day: 'numeric' }) %>
              </div>
            </div>
            <a href="<%= item.url %>" target="_blank" class="text-xs text-brand-400 hover:text-brand-300 shrink-0">View &rarr;</a>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
