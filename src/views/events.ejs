
<div class="max-w-4xl mx-auto">
  <div class="flex items-end justify-between mb-8">
    <div>
      <h1 class="text-2xl font-display font-bold">Meetups & Events</h1>
      <p class="text-sm text-stone-400 mt-1">In-person gatherings across BC & Alberta</p>
    </div>
    <% if (user && user.role === 'admin') { %>
      <a href="/admin/events" class="text-xs text-accent-400 hover:text-accent-300 border border-accent-500/30 px-3 py-1.5 rounded-lg transition">+ Manage Events</a>
    <% } %>
  </div>

  <% if (meetups.length === 0) { %>
    <div class="text-center py-20">
      <div class="text-5xl mb-4">📅</div>
      <p class="text-stone-400 mb-2">No upcoming events yet.</p>
      <p class="text-xs text-stone-600">Check back soon — meetups in Clearwater, Kamloops, and Vancouver are being planned.</p>
    </div>
  <% } else { %>
    <div class="space-y-5">
      <% meetups.forEach(function(m) {
        var isPast = new Date(m.event_date) < new Date();
        var isSoon = !isPast && (new Date(m.event_date) - new Date()) < 7 * 24 * 3600 * 1000;
      %>
        <a href="/events/<%= m.slug %>" class="block bg-stone-900 border <%= isSoon ? 'border-rose-500/30' : 'border-stone-800' %> rounded-xl p-6 hover:border-stone-600 transition">
          <div class="flex items-start justify-between gap-6">
            <div class="flex-1">
              <!-- Date badge -->
              <div class="flex items-center gap-3 mb-3">
                <div class="bg-rose-500/10 border border-rose-500/20 rounded-lg px-3 py-1.5 text-center shrink-0">
                  <div class="text-rose-400 text-xs font-semibold uppercase"><%= new Date(m.event_date).toLocaleDateString('en-CA', { month: 'short' }) %></div>
                  <div class="text-white font-bold text-xl leading-none"><%= new Date(m.event_date).getDate() %></div>
                </div>
                <div>
                  <div class="font-semibold text-base"><%= m.title %></div>
                  <div class="text-sm text-stone-400 mt-0.5"><%= m.location %></div>
                </div>
              </div>
              <% if (m.description) { %>
                <p class="text-sm text-stone-400 leading-relaxed mb-3 line-clamp-2"><%= m.description %></p>
              <% } %>
              <div class="flex items-center gap-4 text-xs text-stone-600">
                <span><%= new Date(m.event_date).toLocaleTimeString('en-CA', { hour: 'numeric', minute: '2-digit' }) %></span>
                <% if (m.rsvp_count > 0) { %>
                  <span class="text-stone-500"><%= m.rsvp_count %> attending</span>
                <% } %>
                <% if (m.capacity) { %>
                  <span><%= m.capacity - m.rsvp_count > 0 ? (m.capacity - m.rsvp_count) + ' spots left' : 'Full' %></span>
                <% } %>
              </div>
            </div>
            <div class="shrink-0 pt-1">
              <span class="text-xs bg-brand-500 text-white px-3 py-1.5 rounded-lg font-medium">RSVP →</span>
            </div>
          </div>
        </a>
      <% }) %>
    </div>
  <% } %>
</div>
