
<div class="max-w-4xl mx-auto">
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-8">
    <div>
      <h1 class="text-2xl font-display font-bold text-white">Meetups &amp; Events</h1>
      <p class="text-sm text-white/50 mt-1">In-person gatherings across BC &amp; Alberta</p>
    </div>
    <% if (user && user.role === 'admin') { %>
      <a href="/admin/events" class="inline-flex items-center gap-2 text-xs text-amber hover:text-amber/80 border border-amber/30 hover:border-amber/50 px-3 py-2 rounded-lg transition-colors w-fit">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        Manage Events
      </a>
    <% } %>
  </div>

  <!-- Upcoming events -->
  <% if (meetups && meetups.length > 0) { %>
    <h2 class="text-xs font-semibold tracking-widest uppercase text-amber mb-4">Upcoming</h2>
    <div class="space-y-4 mb-12">
      <% meetups.forEach(function(m) {
        var d = new Date(m.event_date);
        var isSoon = (d - new Date()) < 7 * 24 * 3600 * 1000;
      %>
        <a href="/events/<%= m.slug %>" class="block bg-warm-dark border <%= isSoon ? 'border-amber/30' : 'border-white/10' %> rounded-2xl p-6 hover:border-amber/40 hover:bg-white/5 transition-all group">
          <div class="flex items-start justify-between gap-5">
            <div class="flex items-start gap-4 flex-1 min-w-0">
              <div class="bg-amber/10 border border-amber/20 rounded-xl px-3 py-2 text-center shrink-0 min-w-[64px]">
                <div class="text-amber text-[10px] font-semibold uppercase tracking-widest"><%= d.toLocaleDateString('en-CA', { month: 'short' }) %></div>
                <div class="text-white font-bold text-2xl leading-none mt-0.5"><%= d.getDate() %></div>
              </div>
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2 flex-wrap mb-1">
                  <% if (m.source === 'facebook') { %>
                    <span class="text-[10px] uppercase tracking-widest font-semibold text-white/50 bg-white/5 border border-white/10 px-1.5 py-0.5 rounded">Facebook</span>
                  <% } %>
                </div>
                <div class="font-semibold text-base text-white group-hover:text-amber transition-colors truncate"><%= m.title %></div>
                <div class="text-sm text-white/50 mt-0.5 flex items-center gap-1.5">
                  <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                  <%= m.location %>
                </div>
                <% if (m.description) { %>
                  <p class="text-sm text-white/50 leading-relaxed mb-3 line-clamp-2 mt-2"><%= m.description %></p>
                <% } %>
                <div class="flex items-center gap-4 text-xs text-white/40 mt-2">
                  <span class="flex items-center gap-1">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <%= d.toLocaleTimeString('en-CA', { hour: 'numeric', minute: '2-digit' }) %>
                  </span>
                  <% if (m.rsvp_count > 0) { %>
                    <span><%= m.rsvp_count %> attending</span>
                  <% } %>
                  <% if (m.capacity) { %>
                    <span><%= m.capacity - m.rsvp_count > 0 ? (m.capacity - m.rsvp_count) + ' spots left' : 'Full' %></span>
                  <% } %>
                </div>
              </div>
            </div>
            <div class="shrink-0 pt-1">
              <span class="inline-flex items-center gap-1.5 text-xs bg-amber group-hover:bg-amber/90 text-white px-3.5 py-2 rounded-lg font-medium transition-colors">
                RSVP
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
              </span>
            </div>
          </div>
        </a>
      <% }) %>
    </div>
  <% } else { %>
    <div class="bg-warm-dark border border-white/10 rounded-2xl p-8 text-center mb-12">
      <div class="w-14 h-14 rounded-xl bg-amber/10 flex items-center justify-center mx-auto mb-4">
        <svg class="w-6 h-6 text-amber" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      </div>
      <p class="text-white/60 text-sm mb-1">No upcoming events yet.</p>
      <p class="text-xs text-white/40">Check back soon &mdash; meetups in Clearwater, Kamloops, and Vancouver are being planned.</p>
    </div>
  <% } %>

  <!-- Past events -->
  <% if (typeof pastMeetups !== 'undefined' && pastMeetups && pastMeetups.length > 0) { %>
    <h2 class="text-xs font-semibold tracking-widest uppercase text-white/40 mb-4">Past Events</h2>
    <div class="space-y-3">
      <% pastMeetups.forEach(function(m) {
        var d = new Date(m.event_date);
      %>
        <div class="bg-warm-dark/60 border border-white/5 rounded-2xl p-5 hover:border-white/10 transition-colors">
          <div class="flex items-start gap-4">
            <div class="bg-white/5 border border-white/10 rounded-xl px-3 py-2 text-center shrink-0 min-w-[64px]">
              <div class="text-white/50 text-[10px] font-semibold uppercase tracking-widest"><%= d.toLocaleDateString('en-CA', { month: 'short' }) %></div>
              <div class="text-white/70 font-bold text-xl leading-none mt-0.5"><%= d.getDate() %></div>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 flex-wrap mb-1">
                <% if (m.source === 'facebook') { %>
                  <span class="text-[10px] uppercase tracking-widest font-semibold text-white/40 bg-white/5 border border-white/10 px-1.5 py-0.5 rounded">Facebook</span>
                <% } %>
              </div>
              <h3 class="font-semibold text-[15px] text-white/80 leading-snug mb-1.5"><%= m.title %></h3>
              <div class="flex items-center gap-3 text-xs text-white/40">
                <span><%= d.toLocaleDateString('en-CA', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                <span class="flex items-center gap-1">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
                  <%= m.location %>
                </span>
                <% if (m.rsvp_count > 0) { %>
                  <span><%= m.rsvp_count %> attended</span>
                <% } %>
              </div>
            </div>
            <% if (m.event_url) { %>
              <a href="<%= m.event_url %>" target="_blank" rel="noopener noreferrer" class="shrink-0 text-xs text-white/50 hover:text-white transition-colors">View &rarr;</a>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
