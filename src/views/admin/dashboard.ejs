
<div>
  <h1 class="text-2xl font-display font-bold mb-6">Admin Dashboard</h1>

  <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="bg-stone-900 border border-brand-600/30 rounded-lg p-5">
      <div class="text-3xl font-bold text-brand-400"><%= stats.subscribers %></div>
      <div class="text-sm text-stone-400">Active Subscribers</div>
    </div>
    <div class="bg-stone-900 border border-stone-800 rounded-lg p-5">
      <div class="text-3xl font-bold"><%= stats.items %></div>
      <div class="text-sm text-stone-400">Collected Items</div>
    </div>
    <div class="bg-stone-900 border border-stone-800 rounded-lg p-5">
      <div class="text-3xl font-bold"><%= stats.sources %></div>
      <div class="text-sm text-stone-400">Active Sources</div>
    </div>
    <div class="bg-stone-900 border <%= stats.pendingSubmissions > 0 ? 'border-amber-500/40' : 'border-stone-800' %> rounded-lg p-5">
      <div class="text-3xl font-bold <%= stats.pendingSubmissions > 0 ? 'text-amber-400' : '' %>"><%= stats.pendingSubmissions %></div>
      <div class="text-sm text-stone-400">Pending Submissions</div>
    </div>
  </div>

  <!-- API Cost Calculator -->
  <div x-data="{ period: 'last30Days' }" class="bg-stone-900 border border-stone-800 rounded-lg p-5 mb-8">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-sm font-semibold tracking-widest uppercase text-stone-500">API Costs</h2>
      <div class="flex gap-1">
        <% ['today', 'last7Days', 'last30Days', 'allTime'].forEach(function(p) { %>
          <button @click="period = '<%= p %>'"
            :class="period === '<%= p %>' ? 'bg-brand-500 text-white' : 'bg-stone-800 text-stone-400 hover:bg-stone-700'"
            class="text-xs px-2.5 py-1 rounded transition">
            <%= p === 'today' ? 'Today' : p === 'last7Days' ? '7d' : p === 'last30Days' ? '30d' : 'All' %>
          </button>
        <% }) %>
      </div>
    </div>

    <% ['today', 'last7Days', 'last30Days', 'allTime'].forEach(function(p) { var period = usage[p]; %>
      <div x-show="period === '<%= p %>'" x-cloak>
        <div class="flex items-baseline gap-2 mb-4">
          <span class="text-2xl font-bold text-brand-400">$<%= (period.totalCostCents / 100).toFixed(2) %></span>
          <span class="text-xs text-stone-500"><%= period.label %></span>
        </div>

        <% if (period.services.length === 0) { %>
          <div class="text-xs text-stone-600">No API usage recorded for this period.</div>
        <% } else { %>
          <div class="space-y-1">
            <%
              // Group by service for summary row
              var byService = {};
              period.services.forEach(function(s) {
                if (!byService[s.service]) byService[s.service] = { calls: 0, cost: 0 };
                byService[s.service].calls += s.totalCalls;
                byService[s.service].cost += s.totalCostCents;
              });
            %>
            <div class="grid grid-cols-4 text-xs text-stone-600 border-b border-stone-800 pb-1 mb-1">
              <div>Service</div>
              <div class="text-right">Calls</div>
              <div class="text-right">Tokens</div>
              <div class="text-right">Cost</div>
            </div>
            <% period.services.forEach(function(s) { %>
              <div class="grid grid-cols-4 text-xs py-0.5">
                <div class="text-stone-400">
                  <span class="<%= s.service === 'anthropic' ? 'text-violet-400' : s.service === 'firecrawl' ? 'text-orange-400' : s.service === 'resend' ? 'text-sky-400' : 'text-amber-400' %>"><%= s.service %></span>
                  <span class="text-stone-600 ml-1"><%= s.operation %></span>
                </div>
                <div class="text-right text-stone-400"><%= s.totalCalls %></div>
                <div class="text-right text-stone-500">
                  <% if (s.totalInputTokens > 0 || s.totalOutputTokens > 0) { %>
                    <%= (s.totalInputTokens / 1000).toFixed(0) %>k / <%= (s.totalOutputTokens / 1000).toFixed(0) %>k
                  <% } else { %>
                    <span class="text-stone-700">&mdash;</span>
                  <% } %>
                </div>
                <div class="text-right font-medium <%= s.totalCostCents > 10 ? 'text-amber-400' : 'text-stone-400' %>">$<%= (s.totalCostCents / 100).toFixed(3) %></div>
              </div>
            <% }) %>
          </div>

          <!-- Service totals -->
          <div class="mt-3 pt-2 border-t border-stone-800 flex flex-wrap gap-4">
            <% Object.keys(byService).forEach(function(svc) { %>
              <div class="text-xs">
                <span class="<%= svc === 'anthropic' ? 'text-violet-400' : svc === 'firecrawl' ? 'text-orange-400' : svc === 'resend' ? 'text-sky-400' : 'text-amber-400' %> font-medium"><%= svc %></span>
                <span class="text-stone-500 ml-1"><%= byService[svc].calls %> calls</span>
                <span class="text-stone-400 ml-1">$<%= (byService[svc].cost / 100).toFixed(2) %></span>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    <% }) %>
  </div>

  <div class="grid sm:grid-cols-3 lg:grid-cols-6 gap-3">
    <a href="/admin/sources" class="bg-stone-900 border border-stone-800 rounded-lg p-4 hover:border-brand-600/50 transition text-center">
      <div class="font-medium">Sources</div>
      <div class="text-xs text-stone-500">Manage scrapers</div>
    </a>
    <a href="/admin/submissions" class="bg-stone-900 border border-stone-800 rounded-lg p-4 hover:border-brand-600/50 transition text-center">
      <div class="font-medium">Submissions</div>
      <div class="text-xs text-stone-500">Review community</div>
    </a>
    <a href="/admin/items" class="bg-stone-900 border border-stone-800 rounded-lg p-4 hover:border-brand-600/50 transition text-center">
      <div class="font-medium">Items</div>
      <div class="text-xs text-stone-500">Manage feed items</div>
    </a>
    <a href="/admin/events" class="bg-stone-900 border border-rose-500/20 rounded-lg p-4 hover:border-rose-500/40 transition text-center">
      <div class="font-medium text-rose-400">Events</div>
      <div class="text-xs text-stone-500">Meetups & RSVPs</div>
    </a>
    <a href="/admin/newsletter" class="bg-stone-900 border border-stone-800 rounded-lg p-4 hover:border-brand-600/50 transition text-center">
      <div class="font-medium">Newsletter</div>
      <div class="text-xs text-stone-500">Build & send issues</div>
    </a>
    <a href="/admin/source-search" class="bg-stone-900 border border-accent-500/30 rounded-lg p-4 hover:border-accent-500/50 transition text-center">
      <div class="font-medium text-accent-400">AI Search</div>
      <div class="text-xs text-stone-500">Find new sources</div>
    </a>
    <a href="/admin/downvoted" class="bg-stone-900 border border-red-500/20 rounded-lg p-4 hover:border-red-500/40 transition text-center">
      <div class="font-medium text-red-400">Downvoted</div>
      <div class="text-xs text-stone-500">Removed items</div>
    </a>
  </div>
</div>
