
<div>
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
    <div>
      <h1 class="text-2xl font-display font-bold">Admin Dashboard</h1>
      <p class="text-sm text-stone-500 mt-1">Manage sources, content, and community</p>
    </div>
    <div class="flex flex-wrap items-center gap-2">
      <form method="POST" action="/admin/sync-zoom">
        <button type="submit" class="inline-flex items-center gap-2 bg-white/5 hover:bg-white/10 text-white/80 hover:text-white text-sm font-medium px-4 py-2.5 rounded-xl border border-white/10 transition-colors active:scale-[0.97]">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
          Sync Zoom
        </button>
      </form>
      <form method="POST" action="/admin/reenrich" onsubmit="return confirm('Re-enrich all unvoted items? This will queue them for AI re-processing with the latest headline prompt. Costs API credits.');">
        <input type="hidden" name="scope" value="unvoted">
        <button type="submit" class="inline-flex items-center gap-2 bg-white/5 hover:bg-white/10 text-white/80 hover:text-white text-sm font-medium px-4 py-2.5 rounded-xl border border-white/10 transition-colors active:scale-[0.97]">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
          Re-enrich
        </button>
      </form>
      <form method="POST" action="/admin/scrape-all" onsubmit="this.querySelector('button').disabled = true; this.querySelector('button').innerHTML = '<svg class=\'w-4 h-4 animate-spin\' fill=\'none\' viewBox=\'0 0 24 24\'><circle class=\'opacity-25\' cx=\'12\' cy=\'12\' r=\'10\' stroke=\'currentColor\' stroke-width=\'4\'></circle><path class=\'opacity-75\' fill=\'currentColor\' d=\'M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z\'></path></svg> Queueing...'">
        <button type="submit" class="inline-flex items-center gap-2 bg-amber hover:bg-amber/90 text-white text-sm font-medium px-4 py-2.5 rounded-xl transition-colors active:scale-[0.97] shadow-lg shadow-amber/20 disabled:opacity-60">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
          Scrape All Sources
        </button>
      </form>
    </div>
  </div>

  <% if (typeof scrapedCount !== 'undefined' && scrapedCount !== null) { %>
    <div class="bg-emerald-500/10 border border-emerald-500/20 text-emerald-300 text-sm px-4 py-3 rounded-xl mb-6 flex items-center gap-2">
      <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      Queued <%= scrapedCount %> scrape job<%= scrapedCount === 1 ? '' : 's' %>. Items will appear in the feed within a few minutes after enrichment.
    </div>
  <% } %>

  <% if (typeof reenrichCount !== 'undefined' && reenrichCount !== null) { %>
    <div class="bg-amber/10 border border-amber/20 text-amber text-sm px-4 py-3 rounded-xl mb-6 flex items-center gap-2">
      <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
      Queued <%= reenrichCount %> items for AI re-enrichment. New headlines will appear in the feed shortly.
    </div>
  <% } %>

  <% if (typeof zoomSyncedCount !== 'undefined' && zoomSyncedCount !== null) { %>
    <div class="bg-emerald-500/10 border border-emerald-500/20 text-emerald-300 text-sm px-4 py-3 rounded-xl mb-6 flex items-center gap-2">
      <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      Zoom sync complete. <%= zoomSyncedCount %> call<%= zoomSyncedCount === 1 ? '' : 's' %> added/updated. View them at <a href="/calls" class="underline hover:text-white">/calls</a>.
    </div>
  <% } %>

  <% if (typeof zoomError !== 'undefined' && zoomError) { %>
    <div class="bg-red-500/10 border border-red-500/20 text-red-300 text-sm px-4 py-3 rounded-xl mb-6 flex items-start gap-2">
      <svg class="w-4 h-4 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
      <div>
        <div class="font-medium">Zoom sync failed</div>
        <div class="text-xs text-red-300/80 mt-0.5"><%= zoomError %></div>
      </div>
    </div>
  <% } %>

  <!-- Stat Tiles -->
  <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="bg-stone-900/60 border border-brand-600/30 rounded-2xl p-5 hover:border-brand-500/50 transition-colors">
      <div class="flex items-start justify-between mb-2">
        <svg class="w-5 h-5 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
      </div>
      <div class="text-3xl font-bold text-brand-400 leading-none mb-1.5"><%= stats.subscribers %></div>
      <div class="text-xs text-stone-500 uppercase tracking-wider font-medium">Active Subscribers</div>
    </div>
    <div class="bg-stone-900/60 border border-stone-800/60 rounded-2xl p-5 hover:border-stone-700/60 transition-colors">
      <div class="flex items-start justify-between mb-2">
        <svg class="w-5 h-5 text-stone-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      </div>
      <div class="text-3xl font-bold leading-none mb-1.5"><%= stats.items %></div>
      <div class="text-xs text-stone-500 uppercase tracking-wider font-medium">Collected Items</div>
    </div>
    <div class="bg-stone-900/60 border border-stone-800/60 rounded-2xl p-5 hover:border-stone-700/60 transition-colors">
      <div class="flex items-start justify-between mb-2">
        <svg class="w-5 h-5 text-stone-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
      </div>
      <div class="text-3xl font-bold leading-none mb-1.5"><%= stats.sources %></div>
      <div class="text-xs text-stone-500 uppercase tracking-wider font-medium">Active Sources</div>
    </div>
    <div class="bg-stone-900/60 border <%= stats.pendingSubmissions > 0 ? 'border-amber-500/40' : 'border-stone-800/60' %> rounded-2xl p-5 hover:border-amber-500/60 transition-colors">
      <div class="flex items-start justify-between mb-2">
        <svg class="w-5 h-5 <%= stats.pendingSubmissions > 0 ? 'text-amber-400' : 'text-stone-500' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
      </div>
      <div class="text-3xl font-bold leading-none mb-1.5 <%= stats.pendingSubmissions > 0 ? 'text-amber-400' : '' %>"><%= stats.pendingSubmissions %></div>
      <div class="text-xs text-stone-500 uppercase tracking-wider font-medium">Pending Submissions</div>
    </div>
  </div>

  <!-- API Cost Calculator -->
  <div x-data="{ period: 'last30Days' }" class="bg-stone-900/60 border border-stone-800/60 rounded-2xl p-6 mb-8">
    <div class="flex items-center justify-between mb-5">
      <h2 class="text-sm font-semibold tracking-widest uppercase text-stone-500 flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        API Costs
      </h2>
      <div class="flex gap-1 bg-stone-800/60 p-1 rounded-lg">
        <% ['today', 'last7Days', 'last30Days', 'allTime'].forEach(function(p) { %>
          <button @click="period = '<%= p %>'"
            :class="period === '<%= p %>' ? 'bg-brand-500 text-white shadow-sm' : 'text-stone-400 hover:text-stone-200'"
            class="text-xs px-3 py-1.5 rounded-md transition-all font-medium">
            <%= p === 'today' ? 'Today' : p === 'last7Days' ? '7d' : p === 'last30Days' ? '30d' : 'All' %>
          </button>
        <% }) %>
      </div>
    </div>

    <% ['today', 'last7Days', 'last30Days', 'allTime'].forEach(function(p) { var period = usage[p]; %>
      <div x-show="period === '<%= p %>'" x-cloak>
        <div class="flex items-baseline gap-2 mb-5">
          <span class="text-3xl font-bold text-brand-400 tabular-nums">$<%= (period.totalCostCents / 100).toFixed(2) %></span>
          <span class="text-xs text-stone-500"><%= period.label %></span>
        </div>

        <% if (period.services.length === 0) { %>
          <div class="text-xs text-stone-600">No API usage recorded for this period.</div>
        <% } else { %>
          <div class="space-y-1">
            <%
              var byService = {};
              period.services.forEach(function(s) {
                if (!byService[s.service]) byService[s.service] = { calls: 0, cost: 0 };
                byService[s.service].calls += s.totalCalls;
                byService[s.service].cost += s.totalCostCents;
              });
            %>
            <div class="grid grid-cols-4 text-[11px] uppercase tracking-wider font-semibold text-stone-600 border-b border-stone-800/60 pb-2 mb-2">
              <div>Service</div>
              <div class="text-right">Calls</div>
              <div class="text-right">Tokens</div>
              <div class="text-right">Cost</div>
            </div>
            <% period.services.forEach(function(s) { %>
              <div class="grid grid-cols-4 text-xs py-1">
                <div class="text-stone-400">
                  <span class="<%= s.service === 'anthropic' ? 'text-violet-400' : s.service === 'firecrawl' ? 'text-orange-400' : s.service === 'resend' ? 'text-sky-400' : 'text-amber-400' %> font-medium"><%= s.service %></span>
                  <span class="text-stone-600 ml-1"><%= s.operation %></span>
                </div>
                <div class="text-right text-stone-400 tabular-nums"><%= s.totalCalls %></div>
                <div class="text-right text-stone-500 tabular-nums">
                  <% if (s.totalInputTokens > 0 || s.totalOutputTokens > 0) { %>
                    <%= (s.totalInputTokens / 1000).toFixed(0) %>k / <%= (s.totalOutputTokens / 1000).toFixed(0) %>k
                  <% } else { %>
                    <span class="text-stone-700">&mdash;</span>
                  <% } %>
                </div>
                <div class="text-right font-medium tabular-nums <%= s.totalCostCents > 10 ? 'text-amber-400' : 'text-stone-400' %>">$<%= (s.totalCostCents / 100).toFixed(3) %></div>
              </div>
            <% }) %>
          </div>

          <div class="mt-4 pt-3 border-t border-stone-800/60 flex flex-wrap gap-x-5 gap-y-2">
            <% Object.keys(byService).forEach(function(svc) { %>
              <div class="text-xs">
                <span class="<%= svc === 'anthropic' ? 'text-violet-400' : svc === 'firecrawl' ? 'text-orange-400' : svc === 'resend' ? 'text-sky-400' : 'text-amber-400' %> font-medium"><%= svc %></span>
                <span class="text-stone-500 ml-1.5 tabular-nums"><%= byService[svc].calls %> calls</span>
                <span class="text-stone-400 ml-1.5 tabular-nums">$<%= (byService[svc].cost / 100).toFixed(2) %></span>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    <% }) %>
  </div>

  <!-- Section: Manage -->
  <h2 class="text-xs font-semibold tracking-widest uppercase text-stone-500 mb-3">Manage</h2>
  <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3 mb-8">
    <a href="/admin/sources" class="bg-stone-900/60 border border-stone-800/60 rounded-xl p-4 hover:border-brand-600/40 hover:bg-stone-900/80 transition-all group">
      <div class="flex items-start gap-3">
        <div class="w-9 h-9 rounded-lg bg-stone-800/60 flex items-center justify-center group-hover:bg-brand-500/10 transition-colors">
          <svg class="w-4 h-4 text-stone-400 group-hover:text-brand-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
        </div>
        <div>
          <div class="font-medium text-sm">Sources</div>
          <div class="text-xs text-stone-500 mt-0.5">Manage scrapers</div>
        </div>
      </div>
    </a>
    <a href="/admin/items" class="bg-stone-900/60 border border-stone-800/60 rounded-xl p-4 hover:border-brand-600/40 hover:bg-stone-900/80 transition-all group">
      <div class="flex items-start gap-3">
        <div class="w-9 h-9 rounded-lg bg-stone-800/60 flex items-center justify-center group-hover:bg-brand-500/10 transition-colors">
          <svg class="w-4 h-4 text-stone-400 group-hover:text-brand-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        </div>
        <div>
          <div class="font-medium text-sm">Items</div>
          <div class="text-xs text-stone-500 mt-0.5">Vote &amp; moderate</div>
        </div>
      </div>
    </a>
    <a href="/admin/submissions" class="bg-stone-900/60 border border-stone-800/60 rounded-xl p-4 hover:border-brand-600/40 hover:bg-stone-900/80 transition-all group">
      <div class="flex items-start gap-3">
        <div class="w-9 h-9 rounded-lg bg-stone-800/60 flex items-center justify-center group-hover:bg-brand-500/10 transition-colors">
          <svg class="w-4 h-4 text-stone-400 group-hover:text-brand-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
        </div>
        <div>
          <div class="font-medium text-sm">Submissions</div>
          <div class="text-xs text-stone-500 mt-0.5">Review community</div>
        </div>
      </div>
    </a>
    <a href="/admin/downvoted" class="bg-stone-900/60 border border-stone-800/60 rounded-xl p-4 hover:border-red-500/40 hover:bg-stone-900/80 transition-all group">
      <div class="flex items-start gap-3">
        <div class="w-9 h-9 rounded-lg bg-stone-800/60 flex items-center justify-center group-hover:bg-red-500/10 transition-colors">
          <svg class="w-4 h-4 text-stone-400 group-hover:text-red-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 14H5.236a2 2 0 01-1.789-2.894l3.5-7A2 2 0 018.736 3h4.018a2 2 0 01.485.06l3.76.94m-7 10v5a2 2 0 002 2h.5a1.5 1.5 0 001.5-1.5V14m-7 0h2m5-1V5a2 2 0 012-2h.5a1.5 1.5 0 011.5 1.5V12m-2 1h2m-2 0h2"/></svg>
        </div>
        <div>
          <div class="font-medium text-sm">Downvoted</div>
          <div class="text-xs text-stone-500 mt-0.5">Removed items</div>
        </div>
      </div>
    </a>
    <a href="/admin/feedback" class="bg-stone-900/60 border border-stone-800/60 rounded-xl p-4 hover:border-sky-500/40 hover:bg-stone-900/80 transition-all group">
      <div class="flex items-start gap-3">
        <div class="w-9 h-9 rounded-lg bg-stone-800/60 flex items-center justify-center group-hover:bg-sky-500/10 transition-colors">
          <svg class="w-4 h-4 text-stone-400 group-hover:text-sky-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
        </div>
        <div>
          <div class="font-medium text-sm">Feedback Log</div>
          <div class="text-xs text-stone-500 mt-0.5">All voted items + notes</div>
        </div>
      </div>
    </a>
    <a href="/admin/comments" class="bg-stone-900/60 border border-stone-800/60 rounded-xl p-4 hover:border-amber-500/40 hover:bg-stone-900/80 transition-all group">
      <div class="flex items-start gap-3">
        <div class="w-9 h-9 rounded-lg bg-stone-800/60 flex items-center justify-center group-hover:bg-amber-500/10 transition-colors">
          <svg class="w-4 h-4 text-stone-400 group-hover:text-amber-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
        </div>
        <div>
          <div class="font-medium text-sm">Comments</div>
          <div class="text-xs text-stone-500 mt-0.5">Moderate flagged</div>
        </div>
      </div>
    </a>
    <a href="/admin/users" class="bg-stone-900/60 border border-stone-800/60 rounded-xl p-4 hover:border-brand-600/40 hover:bg-stone-900/80 transition-all group">
      <div class="flex items-start gap-3">
        <div class="w-9 h-9 rounded-lg bg-stone-800/60 flex items-center justify-center group-hover:bg-brand-500/10 transition-colors">
          <svg class="w-4 h-4 text-stone-400 group-hover:text-brand-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        </div>
        <div>
          <div class="font-medium text-sm">Users</div>
          <div class="text-xs text-stone-500 mt-0.5">Manage roles</div>
        </div>
      </div>
    </a>
    <a href="/admin/waitlist" class="bg-stone-900/60 border border-emerald-500/20 rounded-xl p-4 hover:border-emerald-500/40 hover:bg-stone-900/80 transition-all group">
      <div class="flex items-start gap-3">
        <div class="w-9 h-9 rounded-lg bg-emerald-500/10 flex items-center justify-center group-hover:bg-emerald-500/15 transition-colors">
          <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        </div>
        <div>
          <div class="font-medium text-sm text-emerald-400">Waitlist</div>
