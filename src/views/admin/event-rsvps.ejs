
<div>
  <div class="flex items-center gap-4 mb-6">
    <a href="/admin/events" class="text-xs text-stone-500 hover:text-stone-300">&larr; Events</a>
    <h1 class="text-xl font-display font-bold"><%= meetup.title %> — RSVPs</h1>
    <span class="text-sm text-stone-500"><%= rsvps.length %> registered</span>
  </div>

  <% if (rsvps.length === 0) { %>
    <p class="text-stone-500 text-sm">No RSVPs yet.</p>
  <% } else { %>
    <div class="bg-stone-900 border border-stone-800 rounded-lg overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-stone-800 text-xs text-stone-500 uppercase tracking-wide">
            <th class="text-left px-4 py-3">#</th>
            <th class="text-left px-4 py-3">Name</th>
            <th class="text-left px-4 py-3">Email</th>
            <th class="text-left px-4 py-3">Note</th>
            <th class="text-left px-4 py-3">RSVP'd</th>
          </tr>
        </thead>
        <tbody>
          <% rsvps.forEach(function(r, i) { %>
            <tr class="border-b border-stone-800 hover:bg-stone-800/50">
              <td class="px-4 py-3 text-stone-600"><%= i + 1 %></td>
              <td class="px-4 py-3 font-medium"><%= r.name %></td>
              <td class="px-4 py-3 text-stone-400"><%= r.email %></td>
              <td class="px-4 py-3 text-stone-500 text-xs max-w-xs truncate"><%= r.note || '—' %></td>
              <td class="px-4 py-3 text-stone-600 text-xs"><%= new Date(r.created_at).toLocaleDateString('en-CA') %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="mt-4 text-xs text-stone-600">
      <a href="data:text/csv;charset=utf-8,Name,Email,Note,RSVP Date<%- rsvps.map(function(r) { return '%0A' + encodeURIComponent(r.name) + ',' + encodeURIComponent(r.email) + ',' + encodeURIComponent(r.note || '') + ',' + new Date(r.created_at).toLocaleDateString('en-CA'); }).join('') %>"
         download="<%= meetup.title.replace(/[^a-z0-9]/gi, '-') %>-rsvps.csv"
         class="text-brand-400 hover:text-brand-300">
        Download CSV →
      </a>
    </div>
  <% } %>
</div>
