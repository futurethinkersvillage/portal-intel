
<div x-data="newsletterBuilder()">
  <h1 class="text-2xl font-display font-bold mb-6">Newsletter Builder — Issue #<%= nextIssue %></h1>

  <form method="POST" class="space-y-6">
    <div class="grid sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium mb-1">Subject Line</label>
        <input type="text" name="subject" required placeholder="Portal.Place Intel #<%= nextIssue %> — ..."
          class="w-full bg-stone-900/60 border border-stone-700/60 rounded-lg px-3 py-2.5 text-sm focus:border-brand-500/50 focus:ring-1 focus:ring-brand-500/30 transition-colors">
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">Engagement Question</label>
        <input type="text" name="engagement_question" placeholder="Know a BC grant program we're missing?"
          class="w-full bg-stone-900/60 border border-stone-700/60 rounded-lg px-3 py-2.5 text-sm focus:border-brand-500/50 focus:ring-1 focus:ring-brand-500/30 transition-colors">
      </div>
    </div>

    <div>
      <h2 class="text-lg font-semibold mb-3">Select Items (<span x-text="selectedCount"></span>/15 selected)</h2>
      <p class="text-xs text-stone-400 mb-4">Items are ranked by score. Check the ones to include in the newsletter.</p>

      <div class="space-y-2">
        <% items.forEach(function(item, i) { %>
          <label class="flex items-start gap-3 bg-stone-900/60 border border-stone-800/60 rounded-xl p-4 cursor-pointer hover:border-stone-700/60 transition-colors">
            <input type="checkbox" name="item_ids" value="<%= item.id %>"
              @change="updateCount()"
              <%= i < 15 ? 'checked' : '' %>
              class="mt-1 rounded border-stone-600 bg-stone-800 text-brand-500 focus:ring-brand-500">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2">
                <span class="text-xs font-medium px-2 py-0.5 rounded-full <%= categoryData[item.category]?.badge || 'bg-stone-800 text-stone-400' %>"><%= categoryData[item.category]?.icon || '' %> <%= categoryData[item.category]?.label || item.category %></span>
                <span class="text-xs text-stone-600"><%= item.region.toUpperCase() %></span>
                <span class="text-xs text-stone-600">Score: <%= item.total_score.toFixed(2) %></span>
              </div>
              <div class="font-medium text-sm mt-1"><%= item.title %></div>
              <% if (item.summary) { %>
                <div class="text-xs text-stone-400 mt-1 leading-relaxed"><%= item.summary %></div>
              <% } %>
            </div>
          </label>
        <% }) %>
      </div>
    </div>

    <div class="flex gap-3">
      <button type="submit" formaction="/admin/newsletter/preview" class="bg-stone-700 hover:bg-stone-600 text-white font-medium px-6 py-3 rounded-xl transition-colors active:scale-[0.98]">
        Preview Newsletter
      </button>
      <button type="submit" formaction="/admin/newsletter/send" class="bg-accent-500 hover:bg-accent-600 text-white font-medium px-6 py-3 rounded-xl transition-colors active:scale-[0.98]">
        Create &amp; Send #<%= nextIssue %>
      </button>
    </div>
  </form>
</div>

<script>
function newsletterBuilder() {
  return {
    selectedCount: Math.min(<%= items.length %>, 15),
    updateCount() {
      this.selectedCount = document.querySelectorAll('input[name="item_ids"]:checked').length;
    }
  };
}
</script>
