
<div x-data="{ activeStatus: '' }">
  <h1 class="text-2xl font-display font-bold mb-6">Collected Items</h1>

  <!-- Status Filter Tabs -->
  <div class="flex flex-wrap gap-2 mb-6">
    <button @click="activeStatus = ''" :class="activeStatus === '' ? 'bg-brand-500 text-white' : 'bg-stone-800 text-stone-300 hover:bg-stone-700'"
      class="text-sm px-3 py-1.5 rounded-full transition">All</button>
    <button @click="activeStatus = 'pending'" :class="activeStatus === 'pending' ? 'bg-amber-500 text-white' : 'bg-stone-800 text-stone-300 hover:bg-stone-700'"
      class="text-sm px-3 py-1.5 rounded-full transition">Pending</button>
    <button @click="activeStatus = 'approved'" :class="activeStatus === 'approved' ? 'bg-blue-500 text-white' : 'bg-stone-800 text-stone-300 hover:bg-stone-700'"
      class="text-sm px-3 py-1.5 rounded-full transition">Approved</button>
    <button @click="activeStatus = 'feed'" :class="activeStatus === 'feed' ? 'bg-brand-500 text-white' : 'bg-stone-800 text-stone-300 hover:bg-stone-700'"
      class="text-sm px-3 py-1.5 rounded-full transition">Feed</button>
    <button @click="activeStatus = 'newsletter'" :class="activeStatus === 'newsletter' ? 'bg-accent-500 text-white' : 'bg-stone-800 text-stone-300 hover:bg-stone-700'"
      class="text-sm px-3 py-1.5 rounded-full transition">Newsletter</button>
    <button @click="activeStatus = 'archived'" :class="activeStatus === 'archived' ? 'bg-stone-600 text-white' : 'bg-stone-800 text-stone-300 hover:bg-stone-700'"
      class="text-sm px-3 py-1.5 rounded-full transition">Archived</button>
  </div>

  <div class="space-y-3">
    <% items.forEach(function(item) { %>
      <div x-data="{ feedbackComment: '', showFeedback: false }" class="bg-stone-900/60 border border-stone-800/60 rounded-2xl p-5 hover:border-stone-700/60 transition-colors
        <%= item.admin_vote === 1 ? 'border-l-2 border-l-emerald-500' : item.admin_vote === -1 ? 'border-l-2 border-l-red-500' : item.pinned_at ? 'border-l-2 border-l-amber-400' : '' %>"
           x-show="activeStatus === '' || activeStatus === '<%= item.status %>'"
           x-transition>
        <div class="flex items-start justify-between gap-4">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1.5">
              <span class="text-xs font-medium px-2 py-0.5 rounded-full
                <%= categoryData[item.category]?.badge || 'bg-stone-800 text-stone-400' %>"><%= categoryData[item.category]?.icon || '' %> <%= categoryData[item.category]?.label || item.category %></span>
              <span class="text-xs text-stone-600"><%= item.region.toUpperCase() %></span>
              <span class="text-xs font-medium <%= item.status === 'newsletter' ? 'text-accent-400' : item.status === 'approved' || item.status === 'feed' ? 'text-brand-400' : item.status === 'pending' ? 'text-amber-400' : 'text-stone-600' %>"><%= item.status %></span>
              <span class="text-xs text-stone-600">Score: <%= item.total_score.toFixed(2) %></span>
              <% if (item.pinned_at) { %><span class="text-xs text-amber-400 font-medium">📌 Pinned</span><% } %>
              <% if (item.admin_vote === 1) { %><span class="text-xs text-emerald-400 font-medium">+1</span><% } %>
              <% if (item.admin_vote === -1) { %><span class="text-xs text-red-400 font-medium">-1</span><% } %>
            </div>
            <div class="font-medium text-sm"><%= item.title %></div>
            <% if (item.summary) { %>
              <div class="text-xs text-stone-400 mt-1.5 leading-relaxed"><%= item.summary %></div>
            <% } %>
            <% if (item.admin_comment) { %>
              <div class="text-xs mt-1.5 rounded px-2.5 py-1.5 <%= item.admin_vote === 1 ? 'text-emerald-300 bg-emerald-900/20 border border-emerald-800/30' : 'text-red-300 bg-red-900/20 border border-red-800/30' %>">
                <span class="font-medium"><%= item.admin_vote === 1 ? 'Why good:' : 'Why bad:' %></span> <%= item.admin_comment %>
              </div>
            <% } %>
            <div class="text-xs text-stone-500 mt-2">
              <%= item.source_name || 'User submitted' %> &middot;
              <%= new Date(item.collected_at).toLocaleDateString('en-CA', { month: 'short', day: 'numeric' }) %>
              <% if (item.url) { %>&middot; <a href="<%= item.url %>" target="_blank" class="text-brand-400 hover:text-brand-300">view source</a><% } %>
            </div>
          </div>
          <div class="shrink-0 flex flex-col gap-2 items-end">
            <!-- Action buttons -->
            <div class="flex items-center gap-1">
              <% if (item.admin_vote === 0) { %>
                <button @click="showFeedback = !showFeedback" class="p-1.5 rounded-lg transition text-stone-600 hover:text-brand-400 hover:bg-brand-500/10" title="Rate this item">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/></svg>
                </button>
              <% } else { %>
                <form method="POST" action="/admin/items/<%= item.id %>/vote" class="inline">
                  <input type="hidden" name="vote" value="0">
                  <input type="hidden" name="comment" value="">
                  <button type="submit" class="p-1.5 rounded-lg text-stone-700 hover:text-stone-400 transition" title="Clear vote">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                  </button>
                </form>
              <% } %>
              <!-- Pin button -->
              <form method="POST" action="/admin/items/<%= item.id %>/pin" class="inline">
                <button type="submit" class="p-1.5 rounded-lg transition <%= item.pinned_at ? 'text-amber-400 bg-amber-500/10' : 'text-stone-600 hover:text-amber-400 hover:bg-amber-500/10' %>" title="<%= item.pinned_at ? 'Unpin' : 'Pin to top' %>">
                  <svg class="w-4 h-4" fill="<%= item.pinned_at ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/></svg>
                </button>
              </form>
            </div>
            <!-- Status control -->
            <form method="POST" action="/admin/items/<%= item.id %>/status" class="flex gap-1">
              <select name="status" class="bg-stone-800/60 border border-stone-700/60 rounded-lg px-2.5 py-1.5 text-xs focus:border-brand-500/50 focus:ring-1 focus:ring-brand-500/30 transition-colors">
                <option value="pending" <%= item.status === 'pending' ? 'selected' : '' %>>Pending</option>
                <option value="approved" <%= item.status === 'approved' ? 'selected' : '' %>>Approved</option>
                <option value="feed" <%= item.status === 'feed' ? 'selected' : '' %>>Feed</option>
                <option value="newsletter" <%= item.status === 'newsletter' ? 'selected' : '' %>>Newsletter</option>
                <option value="archived" <%= item.status === 'archived' ? 'selected' : '' %>>Archived</option>
              </select>
              <button type="submit" class="text-xs bg-brand-600 hover:bg-brand-500 text-white px-2 py-1 rounded transition">Set</button>
            </form>
          </div>
        </div>
        <!-- Feedback form (comment required with vote) -->
        <div x-show="showFeedback" x-cloak x-transition class="mt-3 pt-3 border-t border-stone-800">
          <div class="flex gap-2 items-start">
            <input type="text" x-model="feedbackComment" placeholder="Why? (required to vote)"
              class="flex-1 bg-stone-800/60 border border-stone-700/60 rounded-lg px-3 py-2 text-xs focus:border-brand-500/50 focus:ring-1 focus:ring-brand-500/30 transition-colors">
            <form method="POST" action="/admin/items/<%= item.id %>/vote" class="inline">
              <input type="hidden" name="vote" value="1">
              <input type="hidden" name="comment" :value="feedbackComment">
              <button type="submit" :disabled="!feedbackComment.trim()"
                class="p-1.5 rounded-lg transition text-stone-600 hover:text-emerald-400 hover:bg-emerald-500/10 disabled:opacity-30 disabled:cursor-not-allowed" title="Upvote">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 9V5a3 3 0 00-3-3l-4 9v11h11.28a2 2 0 002-1.7l1.38-9a2 2 0 00-2-2.3H14z M4 15h0"/></svg>
              </button>
            </form>
            <form method="POST" action="/admin/items/<%= item.id %>/vote" class="inline">
              <input type="hidden" name="vote" value="-1">
              <input type="hidden" name="comment" :value="feedbackComment">
              <button type="submit" :disabled="!feedbackComment.trim()"
                class="p-1.5 rounded-lg transition text-stone-600 hover:text-red-400 hover:bg-red-500/10 disabled:opacity-30 disabled:cursor-not-allowed" title="Downvote">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 15v4a3 3 0 003 3l4-9V2H5.72a2 2 0 00-2 1.7l-1.38 9a2 2 0 002 2.3H10z M20 2h0"/></svg>
              </button>
            </form>
          </div>
          <p class="text-xs text-stone-600 mt-1">Type a reason, then click thumbs up or down. The scraper learns from your feedback.</p>
        </div>
      </div>
    <% }) %>
  </div>
</div>
