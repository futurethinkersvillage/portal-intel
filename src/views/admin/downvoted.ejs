
<div>
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-display font-bold">Downvoted Items</h1>
      <p class="text-sm text-stone-400 mt-1"><%= items.length %> items removed from feed</p>
    </div>
    <a href="/admin" class="text-sm text-stone-400 hover:text-stone-100 transition">&larr; Dashboard</a>
  </div>

  <% if (items.length === 0) { %>
    <div class="text-center py-16 text-stone-500">
      <div class="text-4xl mb-4">✓</div>
      <p>No downvoted items yet. Use the thumbs down button on the Items page to remove low-quality content.</p>
    </div>
  <% } else { %>
    <div class="space-y-3">
      <% items.forEach(function(item) { %>
        <div class="bg-stone-900/60 border border-stone-800/60 border-l-2 border-l-red-500 rounded-2xl p-5 hover:border-stone-700/60 hover:border-l-red-500 transition-colors">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1.5">
                <span class="text-xs font-medium px-2 py-0.5 rounded-full
                  <%= categoryData[item.category]?.badge || 'bg-stone-800 text-stone-400' %>"><%= categoryData[item.category]?.icon || '' %> <%= categoryData[item.category]?.label || item.category %></span>
                <span class="text-xs text-stone-600"><%= item.region.toUpperCase() %></span>
                <span class="text-xs text-red-400 font-medium">-1 Downvoted</span>
              </div>
              <div class="font-medium text-sm"><%= item.title %></div>
              <% if (item.summary) { %>
                <div class="text-xs text-stone-400 mt-1.5 leading-relaxed"><%= item.summary %></div>
              <% } %>
              <% if (item.admin_comment) { %>
                <div class="text-xs text-red-300 mt-1.5 bg-red-900/20 border border-red-800/30 rounded px-2.5 py-1.5">
                  <span class="text-red-500 font-medium">Reason:</span> <%= item.admin_comment %>
                </div>
              <% } %>
              <div class="text-xs text-stone-500 mt-2">
                <%= item.source_name || 'User submitted' %> &middot;
                <%= new Date(item.collected_at).toLocaleDateString('en-CA', { month: 'short', day: 'numeric' }) %>
              </div>
            </div>
            <form method="POST" action="/admin/items/<%= item.id %>/restore" class="shrink-0">
              <button type="submit" class="text-xs px-3 py-1.5 rounded-lg border border-stone-700/60 text-stone-400 hover:border-brand-500/40 hover:text-brand-400 transition-colors">
                Restore
              </button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
