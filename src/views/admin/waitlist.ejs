
<div>
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-display font-bold">Waitlist</h1>
      <p class="text-sm text-stone-500 mt-1"><%= stats.total %> total &middot; <%= stats.last_24h %> in last 24h &middot; <%= stats.last_7d %> in last 7 days</p>
    </div>
    <div class="flex items-center gap-2">
      <a href="/admin/waitlist.csv" class="inline-flex items-center gap-2 text-xs px-3 py-2 rounded-lg border border-stone-700/60 text-stone-400 hover:border-brand-500/40 hover:text-brand-400 transition-colors">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        Export CSV
      </a>
      <a href="/admin" class="text-sm text-stone-500 hover:text-stone-200 transition-colors flex items-center gap-1.5">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        Dashboard
      </a>
    </div>
  </div>

  <!-- Stat tiles -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8">
    <div class="bg-stone-900/60 border border-brand-600/30 rounded-2xl p-4">
      <div class="text-2xl font-bold text-brand-400 leading-none mb-1.5"><%= stats.total %></div>
      <div class="text-[11px] text-stone-500 uppercase tracking-widest font-semibold">Total Signups</div>
    </div>
    <div class="bg-stone-900/60 border border-stone-800/60 rounded-2xl p-4">
      <div class="text-2xl font-bold text-stone-200 leading-none mb-1.5"><%= stats.last_24h %></div>
      <div class="text-[11px] text-stone-500 uppercase tracking-widest font-semibold">Last 24 hours</div>
    </div>
    <div class="bg-stone-900/60 border border-stone-800/60 rounded-2xl p-4">
      <div class="text-2xl font-bold text-emerald-400 leading-none mb-1.5"><%= stats.google_count %></div>
      <div class="text-[11px] text-stone-500 uppercase tracking-widest font-semibold">Google Sign-ups</div>
    </div>
    <div class="bg-stone-900/60 border border-stone-800/60 rounded-2xl p-4">
      <div class="text-2xl font-bold text-stone-200 leading-none mb-1.5"><%= stats.email_count %></div>
      <div class="text-[11px] text-stone-500 uppercase tracking-widest font-semibold">Email Sign-ups</div>
    </div>
  </div>

  <% if (waitlist.length === 0) { %>
    <div class="text-center py-20">
      <div class="w-16 h-16 rounded-2xl bg-stone-800/50 flex items-center justify-center mx-auto mb-5">
        <svg class="w-7 h-7 text-stone-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
      </div>
      <p class="text-stone-400 text-sm">No signups yet.</p>
    </div>
  <% } else { %>
    <div class="bg-stone-900/60 border border-stone-800/60 rounded-2xl overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-stone-800/60 text-[11px] text-stone-500 uppercase tracking-widest font-semibold">
            <th class="text-left px-5 py-3">Email</th>
            <th class="text-left px-5 py-3">Name</th>
            <th class="text-left px-5 py-3">Source</th>
            <th class="text-left px-5 py-3">Signed up</th>
          </tr>
        </thead>
        <tbody>
          <% waitlist.forEach(function(w) { %>
            <tr class="border-b border-stone-800/40 last:border-0 hover:bg-stone-800/30 transition-colors">
              <td class="px-5 py-3 font-medium text-stone-200 truncate max-w-xs"><%= w.email %></td>
              <td class="px-5 py-3 text-stone-400"><%= w.name || '—' %></td>
              <td class="px-5 py-3">
                <% if (w.source === 'google') { %>
                  <span class="inline-flex items-center gap-1 text-[11px] text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-1.5 py-0.5 rounded">
                    <svg class="w-3 h-3" viewBox="0 0 24 24"><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/></svg>
                    Google
                  </span>
                <% } else { %>
                  <span class="inline-flex items-center gap-1 text-[11px] text-stone-500 bg-stone-800/60 border border-stone-700/60 px-1.5 py-0.5 rounded">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                    Email
                  </span>
                <% } %>
              </td>
              <td class="px-5 py-3 text-xs text-stone-500"><%= new Date(w.created_at).toLocaleDateString('en-CA', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' }) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
