
<div>
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-display font-bold">Comment Moderation</h1>
      <p class="text-sm text-stone-500 mt-1"><%= flagged.length %> flagged or hidden &middot; <%= recent.length %> recent</p>
    </div>
    <a href="/admin" class="text-sm text-stone-500 hover:text-stone-200 transition-colors flex items-center gap-1.5">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
      Dashboard
    </a>
  </div>

  <% if (flagged.length > 0) { %>
    <h2 class="text-xs font-semibold tracking-widest uppercase text-amber-400 mb-3 flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9"/></svg>
      Needs Attention
    </h2>
    <div class="space-y-3 mb-10">
      <% flagged.forEach(function(c) { %>
        <div class="bg-stone-900/60 border <%= c.status === 'flagged' ? 'border-amber-500/30' : 'border-stone-800/60' %> rounded-2xl p-5">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-2 flex-wrap">
                <span class="text-xs font-medium text-stone-300"><%= c.author_name || 'Unknown' %></span>
                <span class="text-xs text-stone-600">&middot;</span>
                <span class="text-xs text-stone-500"><%= new Date(c.created_at).toLocaleDateString('en-CA', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' }) %></span>
                <% if (c.status === 'flagged') { %>
                  <span class="text-[10px] uppercase tracking-widest font-semibold text-amber-400 bg-amber-500/10 border border-amber-500/20 px-1.5 py-0.5 rounded">Flagged</span>
                <% } %>
                <% if (c.status === 'hidden') { %>
                  <span class="text-[10px] uppercase tracking-widest font-semibold text-stone-500 bg-stone-800 border border-stone-700/60 px-1.5 py-0.5 rounded">Hidden</span>
                <% } %>
              </div>
              <p class="text-sm text-stone-300 leading-relaxed whitespace-pre-line mb-2"><%= c.body %></p>
              <% if (c.target_title) { %>
                <div class="text-xs text-stone-600">
                  on <a href="<%= c.target_type === 'item' ? '/feed/' + c.target_id : (c.target_type === 'discussion' ? '/discussions/' + c.target_id : '/events/' + c.target_id) %>" class="text-brand-400 hover:text-brand-300 transition-colors">"<%= c.target_title %>"</a>
                  <span class="text-stone-700"><%= c.target_type %></span>
                </div>
              <% } %>
            </div>
            <div class="flex flex-col gap-1 shrink-0">
              <% if (c.status === 'flagged') { %>
                <form method="POST" :action="'/admin/comments/<%= c.id %>/hide'" onsubmit="event.preventDefault(); fetch('/admin/comments/<%= c.id %>/hide', { method: 'POST' }).then(() => location.reload());">
                  <button type="submit" class="text-xs px-3 py-1.5 rounded-lg border border-stone-700/60 text-stone-400 hover:border-red-500/40 hover:text-red-400 transition-colors w-full">Hide</button>
                </form>
                <form method="POST" action="/admin/comments/<%= c.id %>/restore">
                  <button type="submit" class="text-xs px-3 py-1.5 rounded-lg border border-stone-700/60 text-stone-400 hover:border-emerald-500/40 hover:text-emerald-400 transition-colors w-full">Approve</button>
                </form>
              <% } else if (c.status === 'hidden') { %>
                <form method="POST" action="/admin/comments/<%= c.id %>/restore">
                  <button type="submit" class="text-xs px-3 py-1.5 rounded-lg border border-stone-700/60 text-stone-400 hover:border-brand-500/40 hover:text-brand-400 transition-colors w-full">Restore</button>
                </form>
                <form method="POST" action="/admin/comments/<%= c.id %>/delete" onsubmit="return confirm('Permanently delete this comment? This cascades to replies.')">
                  <button type="submit" class="text-xs px-3 py-1.5 rounded-lg border border-stone-700/60 text-stone-500 hover:border-red-500/40 hover:text-red-400 transition-colors w-full">Delete</button>
                </form>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

  <h2 class="text-xs font-semibold tracking-widest uppercase text-stone-500 mb-3">Recent Comments</h2>
  <% if (recent.length === 0) { %>
    <div class="text-center py-12 text-stone-600 text-sm">No comments yet.</div>
  <% } else { %>
    <div class="space-y-2">
      <% recent.forEach(function(c) { %>
        <div class="bg-stone-900/40 border border-stone-800/40 rounded-xl p-4 flex items-start justify-between gap-4">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs font-medium text-stone-300"><%= c.author_name || 'Unknown' %></span>
              <span class="text-xs text-stone-600">&middot;</span>
              <span class="text-xs text-stone-500"><%= new Date(c.created_at).toLocaleDateString('en-CA', { month: 'short', day: 'numeric' }) %></span>
            </div>
            <p class="text-sm text-stone-400 leading-snug line-clamp-2"><%= c.body %></p>
            <% if (c.target_title) { %>
              <div class="text-[11px] text-stone-600 mt-1">
                on <a href="<%= c.target_type === 'item' ? '/feed/' + c.target_id : '/discussions/' + c.target_id %>" class="text-brand-400/70 hover:text-brand-400 transition-colors">"<%= c.target_title %>"</a>
              </div>
            <% } %>
          </div>
          <button onclick="if (confirm('Hide this comment?')) fetch('/admin/comments/<%= c.id %>/hide', { method: 'POST' }).then(() => location.reload())"
            class="text-xs text-stone-600 hover:text-red-400 transition-colors shrink-0">Hide</button>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
