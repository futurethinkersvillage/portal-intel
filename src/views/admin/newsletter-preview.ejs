
<div class="max-w-4xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-display font-bold">Newsletter Preview — Issue #<%= issueNumber %></h1>
    <a href="/admin/newsletter" class="text-sm text-stone-400 hover:text-stone-100 transition">&larr; Back to Editor</a>
  </div>

  <div class="bg-stone-900 border border-stone-800 rounded-lg p-4 mb-6">
    <div class="flex items-center gap-4 text-sm">
      <span class="text-stone-400">Subject:</span>
      <span class="font-medium"><%= subject %></span>
    </div>
    <div class="flex items-center gap-4 text-sm mt-2">
      <span class="text-stone-400">Items:</span>
      <span><%= itemCount %> items across <%= categoryCount %> categories</span>
    </div>
  </div>

  <!-- Rendered email HTML in a white container simulating email client -->
  <div class="rounded-lg overflow-hidden border border-stone-700 mb-8">
    <div class="bg-stone-800 px-4 py-2 flex items-center gap-2 text-xs text-stone-400">
      <span class="w-3 h-3 rounded-full bg-red-500/60"></span>
      <span class="w-3 h-3 rounded-full bg-amber-500/60"></span>
      <span class="w-3 h-3 rounded-full bg-emerald-500/60"></span>
      <span class="ml-2">Email Preview</span>
    </div>
    <div class="bg-stone-950">
      <iframe id="newsletter-frame" srcdoc="<%- emailHtml.replace(/"/g, '&quot;') %>" style="width: 100%; min-height: 600px; border: none;" onload="this.style.height = this.contentDocument.body.scrollHeight + 'px'"></iframe>
    </div>
  </div>

  <!-- Confirm & Send -->
  <form method="POST" action="/admin/newsletter/send" class="flex items-center gap-4">
    <input type="hidden" name="subject" value="<%= subject %>">
    <input type="hidden" name="engagement_question" value="<%= engagementQuestion %>">
    <% itemIds.forEach(function(id) { %>
      <input type="hidden" name="item_ids" value="<%= id %>">
    <% }) %>
    <button type="submit" class="bg-accent-500 hover:bg-accent-600 text-white font-medium px-6 py-3 rounded-lg transition">
      Confirm &amp; Send Newsletter #<%= issueNumber %>
    </button>
    <a href="/admin/newsletter" class="text-sm text-stone-400 hover:text-stone-100 transition">Cancel</a>
  </form>
</div>
