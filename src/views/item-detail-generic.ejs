<article class="bg-warm-dark border border-white/10 rounded-2xl p-6 sm:p-8">
  <div class="flex flex-wrap items-center gap-2 mb-4">
    <span class="text-xs font-medium px-2.5 py-1 rounded-md <%= categoryData[item.category]?.badge || 'bg-white/5 text-white/60' %>"><%= categoryData[item.category]?.icon || '' %> <%= categoryData[item.category]?.label || item.category %></span>
    <span class="text-[11px] text-white/40 uppercase tracking-wider font-medium"><%= item.region %></span>
    <% if (item.expires_at) { %>
      <span class="text-xs text-amber font-medium flex items-center gap-1">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Closes <%= new Date(item.expires_at).toLocaleDateString('en-CA', { month: 'short', day: 'numeric', year: 'numeric' }) %>
      </span>
    <% } %>
    <% if (item.pinned_at) { %>
      <span class="text-xs text-amber font-medium flex items-center gap-1">
        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M5 5a2 2 0 012-2h6a2 2 0 012 2v14l-5-2.5L5 21V5z"/></svg>
        Pinned
      </span>
    <% } %>
  </div>

  <h1 class="text-2xl sm:text-3xl font-display font-bold text-white mb-4 leading-tight"><%= item.title %></h1>

  <% if (item.summary) { %>
    <p class="text-white/70 leading-relaxed mb-5 text-base"><%= item.summary %></p>
  <% } %>

  <% if (item.ai_actionability) { %>
    <div class="inline-flex items-center gap-2 text-sm text-amber bg-amber/10 border border-amber/20 px-4 py-2 rounded-xl font-medium mb-6">
      <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      <%= item.ai_actionability %>
    </div>
  <% } %>

  <div class="flex flex-wrap items-center gap-4 pt-4 border-t border-white/5">
    <% if (item.url) { %>
      <a href="<%= item.url %>" target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-amber hover:bg-amber/90 text-white text-sm font-medium px-4 py-2.5 rounded-xl transition-colors active:scale-[0.97] shadow-lg shadow-amber/20">
        View Source
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
      </a>
    <% } %>
    <% if (user) { %>
      <form method="POST" action="/feed/save/<%= item.id %>" onsubmit="event.preventDefault(); fetch(this.action, { method: 'POST' }).then(() => location.reload());">
        <button type="submit" class="inline-flex items-center gap-2 text-sm bg-white/5 hover:bg-white/10 text-white/80 hover:text-white px-4 py-2.5 rounded-xl border border-white/10 transition-colors">
          <svg class="w-4 h-4" fill="<%= isSaved ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/></svg>
          <%= isSaved ? 'Saved' : 'Save' %>
        </button>
      </form>
    <% } %>
    <div class="text-xs text-white/40 ml-auto flex items-center gap-2">
      <span><%= item.source_name || 'Community' %></span>
      <span class="w-1 h-1 rounded-full bg-white/20"></span>
      <span><%= new Date(item.collected_at).toLocaleDateString('en-CA', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
    </div>
  </div>
</article>
