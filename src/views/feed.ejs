
<div x-data="feedApp()" x-cloak>
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
    <div>
      <h1 class="text-2xl font-bold">Intel Feed</h1>
      <p class="text-sm text-stone-400">Filtered to your preferences. <span x-text="filteredItems.length"></span> items.</p>
    </div>
    <div class="flex items-center gap-2">
      <a href="/submit" class="bg-brand-500 hover:bg-brand-600 text-white text-sm font-medium px-4 py-2 rounded-lg transition">+ Submit</a>
    </div>
  </div>

  <!-- Filters -->
  <div class="flex flex-wrap gap-2 mb-6">
    <button @click="activeCategory = ''" :class="activeCategory === '' ? 'bg-brand-500 text-white' : 'bg-stone-800 text-stone-300 hover:bg-stone-700'"
      class="text-sm px-3 py-1.5 rounded-full transition">All</button>
    <% categories.forEach(function(cat) { %>
      <button @click="activeCategory = '<%= cat.slug %>'" :class="activeCategory === '<%= cat.slug %>' ? 'bg-brand-500 text-white' : 'bg-stone-800 text-stone-300 hover:bg-stone-700'"
        class="text-sm px-3 py-1.5 rounded-full transition"><%= cat.label %></button>
    <% }) %>
  </div>

  <div class="flex flex-wrap gap-2 mb-8">
    <button @click="activeRegion = ''" :class="activeRegion === '' ? 'bg-stone-600 text-white' : 'bg-stone-800 text-stone-400 hover:bg-stone-700'"
      class="text-xs px-3 py-1 rounded-full transition">All Regions</button>
    <% regions.forEach(function(r) { %>
      <button @click="activeRegion = '<%= r.slug %>'" :class="activeRegion === '<%= r.slug %>' ? 'bg-stone-600 text-white' : 'bg-stone-800 text-stone-400 hover:bg-stone-700'"
        class="text-xs px-3 py-1 rounded-full transition"><%= r.label %></button>
    <% }) %>
  </div>

  <!-- Closing Soon -->
  <template x-if="closingSoon.length > 0 && activeCategory === ''">
    <div class="mb-8">
      <h2 class="text-sm font-medium tracking-widest uppercase text-amber-400 mb-3">Closing Soon</h2>
      <div class="grid gap-2">
        <template x-for="item in closingSoon" :key="item.id">
          <div class="bg-amber-500/5 border border-amber-500/20 rounded-lg p-4 flex items-start justify-between gap-4">
            <div>
              <div class="font-medium text-sm" x-text="item.title"></div>
              <div class="text-xs text-stone-400 mt-1" x-text="item.summary"></div>
              <div class="text-xs text-amber-400 mt-1">Closes <span x-text="formatDate(item.expires_at)"></span></div>
            </div>
            <a :href="item.url" target="_blank" class="text-xs text-brand-400 hover:text-brand-300 shrink-0">View &rarr;</a>
          </div>
        </template>
      </div>
    </div>
  </template>

  <!-- Profiles Section -->
  <template x-if="profiles.length > 0 && activeCategory === '' || activeCategory === 'operators'">
    <div class="mb-8">
      <h2 class="text-sm font-medium tracking-widest uppercase text-stone-500 mb-3">Operator Profiles</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <template x-for="profile in filteredProfiles" :key="profile.id">
          <div class="bg-stone-900 border border-stone-800 rounded-lg p-4">
            <div class="flex items-center gap-2 mb-2">
              <template x-if="profile.user_image">
                <img :src="profile.user_image" class="w-8 h-8 rounded-full" :alt="profile.display_name">
              </template>
              <div>
                <div class="font-medium text-sm" x-text="profile.display_name"></div>
                <div class="text-xs text-stone-500" x-text="profile.region.toUpperCase()"></div>
              </div>
            </div>
            <div class="text-xs text-brand-400 mb-1" x-text="profile.tagline"></div>
            <div class="text-xs text-stone-400" x-text="profile.description?.substring(0, 120) + (profile.description?.length > 120 ? '...' : '')"></div>
            <template x-if="profile.website_url">
              <a :href="profile.website_url" target="_blank" class="text-xs text-brand-400 hover:text-brand-300 mt-2 inline-block">Website &rarr;</a>
            </template>
          </div>
        </template>
      </div>
    </div>
  </template>

  <!-- Items -->
  <div class="space-y-2">
    <template x-for="item in filteredItems" :key="item.id">
      <div class="bg-stone-900 border border-stone-800 rounded-lg p-4 hover:border-stone-700 transition">
        <div class="flex items-start justify-between gap-4">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-stone-800 text-stone-400" x-text="categoryLabel(item.category)"></span>
              <span class="text-xs text-stone-600" x-text="item.region.toUpperCase()"></span>
              <template x-if="item.save_count > 0">
                <span class="text-xs text-stone-600"><span x-text="item.save_count"></span> watching</span>
              </template>
            </div>
            <a :href="item.url" target="_blank" class="font-medium text-sm hover:text-brand-400 transition" x-text="item.title"></a>
            <div class="text-xs text-stone-400 mt-1" x-text="item.summary"></div>
            <div class="flex items-center gap-3 mt-2 text-xs text-stone-500">
              <span x-text="item.source_name || 'User submitted'"></span>
              <span x-text="formatDate(item.collected_at)"></span>
              <template x-if="item.expires_at">
                <span class="text-amber-400">Expires <span x-text="formatDate(item.expires_at)"></span></span>
              </template>
            </div>
          </div>
          <div class="flex items-center gap-2 shrink-0">
            <button @click="toggleSave(item.id)" class="p-1.5 rounded hover:bg-stone-800 transition"
              :class="savedIds.has(item.id) ? 'text-brand-400' : 'text-stone-600'">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                <path d="M5 4a2 2 0 012-2h6a2 2 0 012 2v14l-5-2.5L5 18V4z"/>
              </svg>
            </button>
            <a :href="item.url" target="_blank" class="text-xs text-brand-400 hover:text-brand-300">View &rarr;</a>
          </div>
        </div>
      </div>
    </template>
  </div>

  <template x-if="filteredItems.length === 0">
    <div class="text-center py-16 text-stone-500">
      <p>No items match your current filters.</p>
    </div>
  </template>
</div>

<script>
function feedApp() {
  const categoryMap = {
    <% categories.forEach(function(cat, i) { %>'<%= cat.slug %>': '<%= cat.label %>'<%= i < categories.length - 1 ? ',' : '' %><% }) %>
  };

  return {
    items: <%- items %>,
    profiles: <%- profiles %>,
    closingSoon: <%- closingSoon %>,
    savedIds: new Set(<%- savedIds %>),
    activeCategory: '',
    activeRegion: '',

    get filteredItems() {
      return this.items.filter(item => {
        if (this.activeCategory && item.category !== this.activeCategory) return false;
        if (this.activeRegion && item.region !== this.activeRegion) return false;
        return true;
      });
    },

    get filteredProfiles() {
      return this.profiles.filter(p => {
        if (this.activeCategory && this.activeCategory !== 'operators' && p.category !== this.activeCategory) return false;
        if (this.activeRegion && p.region !== this.activeRegion) return false;
        return true;
      });
    },

    categoryLabel(slug) {
      return categoryMap[slug] || slug;
    },

    formatDate(dateStr) {
      if (!dateStr) return '';
      const d = new Date(dateStr);
      return d.toLocaleDateString('en-CA', { month: 'short', day: 'numeric' });
    },

    async toggleSave(itemId) {
      const res = await fetch('/feed/save/' + itemId, { method: 'POST' });
      const data = await res.json();
      if (data.saved) {
        this.savedIds.add(itemId);
      } else {
        this.savedIds.delete(itemId);
      }
      this.savedIds = new Set(this.savedIds); // trigger reactivity
    }
  };
}
</script>
