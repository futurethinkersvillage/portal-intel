
<div class="max-w-3xl mx-auto">
  <div class="flex items-center gap-3 mb-6">
    <a href="/archive" class="text-xs text-stone-500 hover:text-stone-300 transition-colors flex items-center gap-1.5">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
      Archive
    </a>
    <span class="text-stone-700">/</span>
    <span class="text-xs text-stone-500">Issue #<%= nl.issue_number %> &middot; <%= new Date(nl.sent_at).toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
  </div>

  <div class="bg-stone-900/60 border border-stone-800/60 rounded-2xl overflow-hidden">
    <iframe
      srcdoc="<%- nl.html_body.replace(/"/g, '&quot;') %>"
      class="w-full border-0"
      style="min-height: 800px;"
      onload="this.style.height = (this.contentDocument.body.scrollHeight + 32) + 'px'"
    ></iframe>
  </div>
</div>
