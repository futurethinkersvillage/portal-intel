
<div class="max-w-3xl mx-auto">
  <div class="flex items-center gap-4 mb-6">
    <a href="/archive" class="text-xs text-stone-500 hover:text-stone-300 transition">&larr; Archive</a>
    <span class="text-stone-700">|</span>
    <span class="text-xs text-stone-500">Issue #<%= nl.issue_number %> &middot; <%= new Date(nl.sent_at).toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
  </div>

  <div class="bg-stone-900 border border-stone-800 rounded-lg overflow-hidden">
    <iframe
      srcdoc="<%- nl.html_body.replace(/"/g, '&quot;') %>"
      class="w-full border-0"
      style="min-height: 800px;"
      onload="this.style.height = (this.contentDocument.body.scrollHeight + 32) + 'px'"
    ></iframe>
  </div>
</div>
