
<div class="max-w-4xl mx-auto">
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-8">
    <div>
      <h1 class="text-2xl font-display font-bold flex items-center gap-2.5 text-white">
        <svg class="w-6 h-6 text-amber" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
        Community Calls
      </h1>
      <p class="text-sm text-white/50 mt-1">Recurring Zoom calls on land, portal.place, resilience, and AI</p>
    </div>
  </div>

  <!-- Upcoming calls -->
  <% if (upcomingCalls && upcomingCalls.length > 0) { %>
    <h2 class="text-xs font-semibold tracking-widest uppercase text-amber mb-4">Upcoming</h2>
    <div class="space-y-3 mb-12">
      <% upcomingCalls.forEach(function(c) {
        var d = new Date(c.scheduled_at);
        var isSoon = (d - new Date()) < 7 * 24 * 3600 * 1000;
      %>
        <div class="bg-warm-dark border <%= isSoon ? 'border-amber/30' : 'border-white/10' %> rounded-2xl p-5 hover:border-white/20 transition-colors">
          <div class="flex items-start justify-between gap-5">
            <div class="flex items-start gap-4 flex-1 min-w-0">
              <div class="bg-amber/10 border border-amber/20 rounded-xl px-3 py-2 text-center shrink-0 min-w-[64px]">
                <div class="text-amber text-[10px] font-semibold uppercase tracking-widest"><%= d.toLocaleDateString('en-CA', { month: 'short' }) %></div>
                <div class="text-white font-bold text-xl leading-none mt-0.5"><%= d.getDate() %></div>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1 flex-wrap">
                  <% (c.categories || []).forEach(function(cat) { %>
                    <span class="text-[10px] uppercase tracking-widest font-semibold text-amber/80 bg-amber/10 border border-amber/20 px-1.5 py-0.5 rounded"><%= cat %></span>
                  <% }) %>
                </div>
                <h3 class="font-semibold text-[15px] text-white leading-snug mb-1.5"><%= c.title %></h3>
                <% if (c.description) { %>
                  <p class="text-sm text-white/50 leading-relaxed line-clamp-2 mb-2"><%= c.description %></p>
                <% } %>
                <div class="flex items-center gap-3 text-xs text-white/40">
                  <span class="flex items-center gap-1">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <%= d.toLocaleDateString('en-CA', { weekday: 'short', month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' }) %>
                  </span>
                  <% if (c.duration_minutes) { %>
                    <span><%= c.duration_minutes %> min</span>
                  <% } %>
                </div>
              </div>
            </div>
            <div class="shrink-0 flex flex-col gap-2">
              <% if (c.join_url) { %>
                <a href="<%= c.join_url %>" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-amber hover:bg-amber/90 text-white text-xs font-medium px-4 py-2 rounded-lg transition-colors active:scale-[0.97] shadow-lg shadow-amber/20 whitespace-nowrap">
                  Join Call
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                </a>
              <% } %>
              <% if (c.registration_url) { %>
                <a href="<%= c.registration_url %>" target="_blank" rel="noopener noreferrer" class="text-xs text-white/50 hover:text-white transition-colors text-center whitespace-nowrap">Register &rarr;</a>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <div class="bg-warm-dark border border-white/10 rounded-2xl p-8 text-center mb-12">
      <div class="w-14 h-14 rounded-xl bg-amber/10 flex items-center justify-center mx-auto mb-4">
        <svg class="w-6 h-6 text-amber" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
      </div>
      <p class="text-white/60 text-sm mb-1">No upcoming calls scheduled.</p>
      <p class="text-xs text-white/40">Check back soon &mdash; calls are synced automatically.</p>
    </div>
  <% } %>

  <!-- Past calls -->
  <% if (pastCalls && pastCalls.length > 0) { %>
    <h2 class="text-xs font-semibold tracking-widest uppercase text-white/40 mb-4">Past Calls</h2>
    <div class="space-y-3">
      <% pastCalls.forEach(function(c) {
        var d = new Date(c.scheduled_at);
      %>
        <div class="bg-warm-dark/60 border border-white/5 rounded-2xl p-5 hover:border-white/10 transition-colors">
          <div class="flex items-start justify-between gap-5">
            <div class="flex items-start gap-4 flex-1 min-w-0">
              <div class="bg-white/5 border border-white/10 rounded-xl px-3 py-2 text-center shrink-0 min-w-[64px]">
                <div class="text-white/50 text-[10px] font-semibold uppercase tracking-widest"><%= d.toLocaleDateString('en-CA', { month: 'short' }) %></div>
                <div class="text-white/70 font-bold text-xl leading-none mt-0.5"><%= d.getDate() %></div>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1 flex-wrap">
                  <% (c.categories || []).forEach(function(cat) { %>
                    <span class="text-[10px] uppercase tracking-widest font-semibold text-white/50 bg-white/5 border border-white/10 px-1.5 py-0.5 rounded"><%= cat %></span>
                  <% }) %>
                </div>
                <h3 class="font-semibold text-[15px] text-white/80 leading-snug mb-1.5"><%= c.title %></h3>
                <% if (c.summary || c.description) { %>
                  <p class="text-sm text-white/50 leading-relaxed line-clamp-2 mb-2"><%= c.summary || c.description %></p>
                <% } %>
                <div class="flex items-center gap-3 text-xs text-white/40">
                  <span><%= d.toLocaleDateString('en-CA', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                  <% if (c.duration_minutes) { %>
                    <span><%= c.duration_minutes %> min</span>
                  <% } %>
                </div>
              </div>
            </div>
            <% if (c.recording_url) { %>
              <a href="<%= c.recording_url %>" target="_blank" rel="noopener noreferrer" class="shrink-0 inline-flex items-center gap-1.5 bg-white/5 hover:bg-white/10 text-white/70 hover:text-white text-xs font-medium px-3 py-2 rounded-lg border border-white/10 transition-colors whitespace-nowrap">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Recording
              </a>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
