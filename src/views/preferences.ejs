
<div class="max-w-2xl mx-auto">
  <% if (isOnboarding) { %>
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold mb-2">Welcome to Portal.Place Intel</h1>
      <p class="text-stone-400">Choose the categories you care about. You can change these anytime.</p>
    </div>
  <% } else { %>
    <h1 class="text-2xl font-bold mb-6">Preferences</h1>
    <% if (success) { %>
      <div class="bg-brand-400/10 text-brand-400 text-sm px-4 py-3 rounded-lg mb-6">Preferences saved.</div>
    <% } %>
  <% } %>

  <form method="POST" action="/preferences" class="space-y-8">
    <div>
      <h2 class="text-lg font-semibold mb-3">Categories</h2>
      <p class="text-sm text-stone-400 mb-4">Select the topics you want in your weekly digest.</p>
      <div class="grid sm:grid-cols-2 gap-3">
        <% categories.forEach(function(cat) { %>
          <label class="flex items-start gap-3 bg-stone-900 border border-stone-800 rounded-lg p-4 cursor-pointer hover:border-stone-700 transition">
            <input type="checkbox" name="preferences" value="<%= cat.slug %>"
              <%= prefs.preferences && prefs.preferences.includes(cat.slug) ? 'checked' : '' %>
              class="mt-0.5 rounded border-stone-600 bg-stone-800 text-brand-500 focus:ring-brand-500">
            <div>
              <div class="font-medium text-sm"><%= cat.label %></div>
              <div class="text-xs text-stone-500"><%= cat.description %></div>
            </div>
          </label>
        <% }) %>
      </div>
    </div>

    <div>
      <h2 class="text-lg font-semibold mb-3">Daily Alerts</h2>
      <p class="text-sm text-stone-400 mb-4">Get same-day email notifications for these categories (in addition to the weekly digest).</p>
      <div class="grid sm:grid-cols-2 gap-3">
        <% categories.forEach(function(cat) { %>
          <label class="flex items-center gap-3 bg-stone-900 border border-stone-800 rounded-lg px-4 py-3 cursor-pointer hover:border-stone-700 transition">
            <input type="checkbox" name="alert_categories" value="<%= cat.slug %>"
              <%= prefs.alert_categories && prefs.alert_categories.includes(cat.slug) ? 'checked' : '' %>
              class="rounded border-stone-600 bg-stone-800 text-brand-500 focus:ring-brand-500">
            <span class="text-sm"><%= cat.label %></span>
          </label>
        <% }) %>
      </div>
    </div>

    <div>
      <h2 class="text-lg font-semibold mb-3">Digest Frequency</h2>
      <div class="flex gap-4">
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="radio" name="digest_frequency" value="weekly" <%= prefs.digest_frequency === 'weekly' ? 'checked' : '' %>
            class="border-stone-600 bg-stone-800 text-brand-500 focus:ring-brand-500">
          <span class="text-sm">Weekly</span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="radio" name="digest_frequency" value="daily" <%= prefs.digest_frequency === 'daily' ? 'checked' : '' %>
            class="border-stone-600 bg-stone-800 text-brand-500 focus:ring-brand-500">
          <span class="text-sm">Daily</span>
        </label>
      </div>
    </div>

    <button type="submit" class="bg-brand-500 hover:bg-brand-600 text-white font-medium px-6 py-3 rounded-lg transition w-full sm:w-auto">
      <%= isOnboarding ? 'Get Started' : 'Save Preferences' %>
    </button>
  </form>
</div>
