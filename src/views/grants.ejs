
<div x-data="{ view: 'calendar' }">
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-8">
    <div>
      <h1 class="text-2xl font-display font-bold text-amber-400">💰 Grant Deadlines</h1>
      <p class="text-sm text-stone-400 mt-1">BC & Alberta grants sorted by deadline — act before they close</p>
    </div>
    <div class="flex items-center gap-3">
      <!-- Region filter -->
      <div class="flex gap-1">
        <a href="/grants" class="text-xs px-2.5 py-1.5 rounded border <%= !activeRegion ? 'border-amber-500/50 text-amber-400' : 'border-stone-700 text-stone-400 hover:border-stone-600' %> transition">All</a>
        <% regions.forEach(function(r) { %>
          <a href="/grants?region=<%= r.slug %>" class="text-xs px-2.5 py-1.5 rounded border <%= activeRegion === r.slug ? 'border-amber-500/50 text-amber-400' : 'border-stone-700 text-stone-400 hover:border-stone-600' %> transition"><%= r.label %></a>
        <% }) %>
      </div>
    </div>
  </div>

  <% if (months.length === 0 && noDeadline.length === 0) { %>
    <div class="text-center py-16">
      <div class="text-4xl mb-4">💰</div>
      <p class="text-stone-400">No grants in the feed yet.</p>
      <% if (!user) { %><a href="/" class="text-sm text-brand-400 mt-2 inline-block">Sign in to access the full feed →</a><% } %>
    </div>
  <% } else { %>

    <!-- Months with deadlines -->
    <% months.forEach(function(month) { %>
      <div class="mb-10">
        <h2 class="text-sm font-semibold tracking-widest uppercase text-amber-400/70 mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-amber-400 animate-pulse"></span>
          <%= month.label %>
          <span class="text-stone-700 font-normal">(<%= month.items.length %>)</span>
        </h2>
        <div class="space-y-3">
          <% month.items.forEach(function(item) {
            var daysLeft = item.expires_at ? Math.ceil((new Date(item.expires_at) - new Date()) / 86400000) : null;
            var urgency = daysLeft !== null && daysLeft <= 3 ? 'border-red-500/40' : daysLeft !== null && daysLeft <= 7 ? 'border-amber-500/30' : 'border-stone-800';
          %>
            <div class="bg-stone-900 border <%= urgency %> rounded-xl p-5 hover:border-stone-700 transition">
              <div class="flex items-start gap-4">
                <div class="flex-1 min-w-0">
                  <div class="flex flex-wrap items-center gap-2 mb-2">
                    <% if (daysLeft !== null) { %>
                      <span class="text-xs font-semibold px-2 py-0.5 rounded-full <%= daysLeft <= 3 ? 'bg-red-500/20 text-red-400' : daysLeft <= 7 ? 'bg-amber-500/20 text-amber-400' : 'bg-stone-800 text-stone-400' %>">
                        <%= daysLeft <= 0 ? 'Closing today' : daysLeft + 'd left' %>
                      </span>
                    <% } %>
                    <span class="text-xs text-stone-600 uppercase"><%= item.region %></span>
                    <% if (item.source_name) { %><span class="text-xs text-stone-700"><%= item.source_name %></span><% } %>
                  </div>
                  <% if (item.url) { %>
                    <a href="<%= item.url %>" target="_blank" class="font-semibold text-sm text-stone-100 hover:text-amber-300 transition block mb-2"><%= item.title %></a>
                  <% } else { %>
                    <div class="font-semibold text-sm text-stone-100 mb-2"><%= item.title %></div>
                  <% } %>
                  <% if (item.summary) { %>
                    <p class="text-sm text-stone-400 leading-relaxed mb-2"><%= item.summary %></p>
                  <% } %>
                  <% if (item.ai_actionability) { %>
                    <div class="inline-flex items-center gap-1 text-xs text-brand-300 bg-brand-900/40 border border-brand-800/50 px-2.5 py-1 rounded-full font-medium">
                      → <%= item.ai_actionability %>
                    </div>
                  <% } %>
                </div>
                <% if (item.url) { %>
                  <a href="<%= item.url %>" target="_blank" class="shrink-0 text-xs bg-amber-500/10 hover:bg-amber-500/20 text-amber-400 px-3 py-1.5 rounded-lg transition font-medium border border-amber-500/20 whitespace-nowrap">
                    Apply →
                  </a>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    <% }) %>

    <!-- No-deadline grants -->
    <% if (noDeadline.length > 0) { %>
      <div class="mb-10">
        <h2 class="text-sm font-semibold tracking-widest uppercase text-stone-500 mb-4">Open / No Set Deadline</h2>
        <div class="space-y-3">
          <% noDeadline.forEach(function(item) { %>
            <div class="bg-stone-900 border border-stone-800 rounded-xl p-5 hover:border-stone-700 transition">
              <div class="flex items-start gap-4">
                <div class="flex-1">
                  <% if (item.url) { %>
                    <a href="<%= item.url %>" target="_blank" class="font-semibold text-sm text-stone-100 hover:text-amber-300 transition block mb-2"><%= item.title %></a>
                  <% } else { %>
                    <div class="font-semibold text-sm text-stone-100 mb-2"><%= item.title %></div>
                  <% } %>
                  <% if (item.summary) { %><p class="text-sm text-stone-400 leading-relaxed"><%= item.summary %></p><% } %>
                </div>
                <% if (item.url) { %>
                  <a href="<%= item.url %>" target="_blank" class="shrink-0 text-xs text-stone-400 hover:text-stone-200 px-3 py-1.5 rounded-lg border border-stone-700 transition">View →</a>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

  <% } %>

  <% if (!user) { %>
    <div class="mt-8 bg-stone-900 border border-amber-500/20 rounded-xl p-8 text-center">
      <p class="text-stone-300 mb-4 text-sm">Sign in to get daily alerts when new grants are posted in your categories.</p>
      <a href="/api/auth/sign-in/social?provider=google&callbackURL=/preferences"
         class="inline-flex items-center gap-2 bg-white text-stone-900 font-semibold px-5 py-2.5 rounded-xl hover:bg-stone-100 transition text-sm">
        <svg class="w-4 h-4" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
        Get Grant Alerts
      </a>
    </div>
  <% } %>
</div>
